---
interface Props {
  slot: 'sidebar' | 'header-banner' | 'in-content' | 'footer';
  class?: string;
}

const dimensions = {
  'sidebar':       { minHeight: '250px', minWidth: '300px' },
  'header-banner': { minHeight: '90px',  minWidth: '100%' },
  'in-content':    { minHeight: '280px', minWidth: '100%' },
  'footer':        { minHeight: '90px',  minWidth: '100%' },
};

const { slot, class: className = '' } = Astro.props;
const dim = dimensions[slot];
---

<div
  class:list={[
    'ad-container relative flex items-center justify-center overflow-hidden rounded-xl border border-border-subtle bg-surface/30', 
    className
  ]}
  style={`min-height: ${dim.minHeight}; min-width: ${dim.minWidth}; contain: layout style;`}
  data-ad-slot={slot}
  aria-label="Advertisement placeholder"
>
  <!-- AdSense code placeholder for now -->
  <div class="absolute inset-0 flex flex-col items-center justify-center text-text-muted opacity-40">
    <span class="text-micro uppercase tracking-widest font-semibold mb-1">Advertisement</span>
    <span class="text-xs">({dim.minWidth} x {dim.minHeight})</span>
  </div>
</div>
