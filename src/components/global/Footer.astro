---
---
<footer class="border-t border-border-subtle bg-base mt-auto">
  <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <div class="col-span-1 md:col-span-2">
        <a href="/" class="flex items-center gap-2 mb-4">
          <div class="bg-accent/10 p-1.5 rounded-lg border border-accent/20">
            <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="square" stroke-linejoin="miter" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <span class="font-bold text-lg tracking-tight">MyToolboxHub</span>
        </a>
        <p class="text-text-secondary text-sm max-w-xs leading-relaxed">
          Your premium, blazing-fast developer utility suite. Built with Astro & Tailwind for zero-JS performance.
        </p>
      </div>
      
      <div>
        <h3 class="text-xs font-semibold text-text-primary tracking-wider uppercase mb-4">Categories</h3>
        <ul class="space-y-3 text-sm text-text-secondary">
          <li><a href="/" class="hover:text-accent transition-colors">Converters</a></li>
          <li><a href="/" class="hover:text-accent transition-colors">Formatters</a></li>
          <li><a href="/" class="hover:text-accent transition-colors">Dev Tools</a></li>
          <li><a href="/" class="hover:text-accent transition-colors">Generators</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-semibold text-text-primary tracking-wider uppercase mb-4">Legal</h3>
        <ul class="space-y-3 text-sm text-text-secondary">
          <li><a href="/privacy" class="hover:text-accent transition-colors">Privacy Policy</a></li>
          <li><a href="/terms" class="hover:text-accent transition-colors">Terms of Service</a></li>
          <li><a href="/about" class="hover:text-accent transition-colors">About Us</a></li>
          <li><a href="/contact" class="hover:text-accent transition-colors">Contact</a></li>
        </ul>
      </div>
    </div>
    <div class="mt-12 pt-8 border-t border-border-subtle flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-text-muted">
      <p>&copy; {new Date().getFullYear()} MyToolboxHub. All rights reserved.</p>
      <div class="flex items-center gap-1">
        <span>Powered by</span>
        <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">Astro</a>
      </div>
    </div>
  </div>
</footer>
