---
import SearchModal from './SearchModal.astro';
---
<header class="sticky top-0 z-40 w-full backdrop-blur-xl bg-void/80 border-b border-border-subtle">
  <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
    <div class="flex items-center gap-4">
      <a href="/" class="flex items-center gap-2 focus-glow rounded-lg px-2 py-1 -ml-2 group">
        <div class="bg-accent/10 p-1.5 rounded-lg border border-accent/20 group-hover:border-accent/40 transition-colors">
          <svg class="w-6 h-6 text-accent drop-shadow-glow-sm" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="square" stroke-linejoin="miter" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </div>
        <span class="font-bold text-xl tracking-tight hidden sm:block text-text-primary group-hover:text-white transition-colors">MyToolboxHub</span>
      </a>
    </div>

    <div class="flex items-center gap-4">
      <!-- Search Trigger (Cmd+K) -->
      <button 
        id="headerSearchBtn"
        type="button" 
        class="hidden sm:flex items-center gap-2 px-3 py-1.5 text-sm text-text-muted bg-surface hover:bg-elevated border border-border-subtle rounded-lg transition-colors focus-glow w-64 justify-between"
      >
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <span>Search tools...</span>
        </div>
        <kbd class="hidden lg:inline-flex items-center gap-1 font-sans text-xs bg-void border border-border-default px-1.5 py-0.5 rounded text-text-secondary">
          <span class="text-xs">⌘</span>K
        </kbd>
      </button>

      <a href="https://github.com/mytoolboxhub" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-text-primary transition-colors focus-glow rounded-lg p-2 bg-surface border border-border-subtle hover:bg-elevated">
        <span class="sr-only">GitHub</span>
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>
  </div>
</header>
<SearchModal />
