---
import SearchModal from './SearchModal.astro';
---
<header class="sticky top-0 z-40 w-full backdrop-blur-xl bg-void/80 border-b border-border-subtle">
  <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
    <div class="flex items-center gap-4">
      <a href="/" class="flex items-center gap-2 focus-glow rounded-lg px-2 py-1 -ml-2 group">
        <div class="bg-accent/10 p-1.5 rounded-lg border border-accent/20 group-hover:border-accent/40 transition-colors">
          <svg class="w-6 h-6 text-accent drop-shadow-glow-sm" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="square" stroke-linejoin="miter" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </div>
        <span class="font-bold text-xl tracking-tight hidden sm:block text-text-primary group-hover:text-white transition-colors">MyToolboxHub</span>
      </a>
    </div>

    <div class="flex items-center gap-4">
      <!-- Search Trigger (Cmd+K) -->
      <button 
        id="headerSearchBtn"
        type="button" 
        class="hidden sm:flex items-center gap-2 px-3 py-1.5 text-sm text-text-muted bg-surface hover:bg-elevated border border-border-subtle rounded-lg transition-colors focus-glow w-64 justify-between"
      >
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <span>Search tools...</span>
        </div>
        <kbd class="hidden lg:inline-flex items-center gap-1 font-sans text-xs bg-void border border-border-default px-1.5 py-0.5 rounded text-text-secondary">
          <span class="text-xs">⌘</span>K
        </kbd>
      </button>
    </div>
  </div>
</header>
<SearchModal />
