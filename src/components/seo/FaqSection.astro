---
interface Props {
  title?: string;
  faqs: {
    question: string;
    answer: string; // HTML content
    text: string; // Plain text for JSON-LD
  }[];
}
const { title = "Frequently Asked Questions", faqs } = Astro.props;
---
<section class="mb-12">
  <h2 class="text-2xl font-bold mb-6 text-text-primary">{title}</h2>
  
  <div class="space-y-4">
    {faqs.map((faq, i) => (
      <details class="group bg-surface border border-border-subtle rounded-lg open:bg-base transition-colors" open={i === 0}>
        <summary class="flex items-center justify-between cursor-pointer p-4 font-medium text-text-primary">
          {faq.question}
          <span class="transition group-open:rotate-180">
            <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
          </span>
        </summary>
        <div class="p-4 pt-0 text-text-secondary leading-relaxed" set:html={faq.answer}></div>
      </details>
    ))}
  </div>

  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.text
      }
    }))
  })}>
  </script>
</section>
