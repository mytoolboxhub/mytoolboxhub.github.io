---
interface Props {
  title: string;
  steps: {
    name: string;
    text: string;
    description: string; // HTML content
  }[];
}
const { title, steps } = Astro.props;
---
<section class="mb-12">
  <h2 class="text-2xl font-bold mb-6 text-text-primary">{title}</h2>
  
  <div class="space-y-6">
    {steps.map((step, index) => (
      <div class="glass p-6">
        <h3 class="text-lg font-semibold text-accent mb-2">Step {index + 1}: {step.name}</h3>
        <div class="text-text-secondary leading-relaxed" set:html={step.description}></div>
      </div>
    ))}
  </div>

  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": title,
    "step": steps.map(s => ({
      "@type": "HowToStep",
      "name": s.name,
      "text": s.text
    }))
  })}>
  </script>
</section>
