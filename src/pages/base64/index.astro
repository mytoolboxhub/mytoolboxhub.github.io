---
import ToolLayout from '../../layouts/ToolLayout.astro';
import HowToSection from '../../components/seo/HowToSection.astro';
import FaqSection from '../../components/seo/FaqSection.astro';
import TechnicalExplainer from '../../components/seo/TechnicalExplainer.astro';
import { tools } from '../../lib/tool-registry';

const tool = tools.find(t => t.id === 'base64-encoder')!;
---

<ToolLayout tool={tool}>
  <div class="space-y-6">
    <!-- Controls -->
    <div class="glass p-4 flex flex-wrap gap-6 items-center justify-between">
      <div class="flex items-center gap-6">
        <div class="flex bg-surface border border-border-default rounded-lg p-1">
          <button id="modeEncode" class="px-4 py-1.5 text-sm font-medium rounded-md bg-accent text-void transition-all focus-glow">Encode</button>
          <button id="modeDecode" class="px-4 py-1.5 text-sm font-medium rounded-md text-text-secondary hover:text-text-primary transition-all focus-glow">Decode</button>
        </div>
        
        <div class="flex items-center gap-2" id="urlSafeWrapper">
          <input type="checkbox" id="urlSafe" class="w-4 h-4 rounded border-border-default bg-surface text-accent focus-glow" />
          <label for="urlSafe" class="text-sm font-medium text-text-secondary">URL-Safe</label>
        </div>
      </div>
    </div>

    <!-- Error Banner -->
    <div id="errorBanner" class="hidden bg-error/10 border border-error/30 text-error px-4 py-3 rounded-lg text-sm flex items-start gap-3 animate-fade-in-down">
      <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <div>
        <strong class="block font-semibold mb-1">Error</strong>
        <span id="errorMessage"></span>
      </div>
    </div>

    <!-- Layout Grid -->
    <div class="grid grid-cols-1 gap-6">
      <!-- Input Panel -->
      <div class="flex flex-col">
        <div class="flex justify-between items-center mb-2">
          <label id="inputLabel" for="input" class="text-sm font-semibold text-text-primary">Text to Encode</label>
          <div class="flex gap-4 items-center">
            <span id="inputSize" class="text-xs text-text-muted">0 B</span>
          </div>
        </div>
        <textarea 
          id="input" 
          class="min-h-[200px] w-full bg-surface/50 border border-border-subtle rounded-xl p-4 font-mono text-sm text-text-primary resize-y focus-glow transition-colors"
          placeholder="Type or paste here..."
          spellcheck="false"
        ></textarea>
        
        <!-- File Drop Zone for Encode Mode -->
        <div id="fileDropZone" class="mt-4 p-8 border-2 border-dashed border-border-default rounded-xl flex flex-col items-center justify-center text-center hover:bg-surface/50 hover:border-accent/50 transition-colors cursor-pointer bg-void">
          <svg class="w-8 h-8 text-text-muted mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" /></svg>
          <p class="text-sm font-medium text-text-primary mb-1">Click to upload or drag and drop a file</p>
          <p class="text-xs text-text-muted">Images, PDFs, or any binary file to encode to Base64</p>
          <input type="file" id="fileInput" class="hidden" />
        </div>
      </div>

      <!-- Arrow Divider -->
      <div class="flex justify-center -my-3 relative z-10 hidden sm:flex">
        <div class="bg-surface border border-border-subtle p-2 rounded-full text-accent shadow-lg">
          <svg class="w-5 h-5 transform rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>
        </div>
      </div>

      <!-- Output Panel -->
      <div class="flex flex-col">
        <div class="flex justify-between items-center mb-2">
          <label id="outputLabel" for="output" class="text-sm font-semibold text-text-primary">Base64 Output</label>
          <div class="flex gap-3 items-center">
            <span id="outputSize" class="text-xs text-text-muted hidden">0 B</span>
            <button id="copyBtn" class="text-xs text-accent hover:text-accent-hover transition-colors flex items-center gap-1 font-medium">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
              Copy
            </button>
            <button id="downloadBtn" class="text-xs text-accent hover:text-accent-hover transition-colors flex items-center gap-1 font-medium">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
              Download
            </button>
          </div>
        </div>
        <textarea 
          id="output" 
          class="min-h-[200px] w-full bg-void border border-border-subtle rounded-xl p-4 font-mono text-sm text-text-secondary resize-y focus-glow"
          placeholder="Result will appear here..."
          readonly
        ></textarea>
      </div>
    </div>
  </div>

  <Fragment slot="content">
    <HowToSection 
      title="How to Encode and Decode Base64 Online"
      steps={[
        {
          name: "Select Your Mode",
          text: "Choose whether you want to encode text/files into Base64, or decode a Base64 string back into readable text.",
          description: "Choose whether you want to <strong>Encode</strong> text/files into Base64, or <strong>Decode</strong> a Base64 string back into readable text using the toggle at the top."
        },
        {
          name: "Enter Text or Upload File",
          text: "Type or paste your text into the input box. If you are encoding, you can also drag and drop an image or binary file into the drop zone.",
          description: "Type or paste your text into the input box. If you are encoding, you can also drag and drop an image or binary file into the drop zone."
        },
        {
          name: "Configure Options (Optional)",
          text: "If encoding for use in a URL, check the URL-Safe box to use a URL-friendly alphabet.",
          description: "If encoding for use in a URL, check the <strong>URL-Safe</strong> box to use a URL-friendly alphabet that replaces <code>+</code> and <code>/</code>."
        },
        {
          name: "Copy or Download",
          text: "The conversion happens instantly as you type. Copy the result or download it as a text file.",
          description: "The conversion happens instantly as you type. Copy the result or download it as a text file."
        }
      ]}
    />
    <TechnicalExplainer 
      title="What Is Base64 Encoding? A Developer's Guide"
      sections={[
        {
          title: "The Purpose of Base64",
          content: "Base64 is an encoding scheme used to represent binary data in an ASCII string format. It's designed to carry data stored in binary formats across channels that only reliably support text content. Common use cases include embedding image data directly into HTML/CSS (Data URIs), encoding credentials for Basic HTTP Authentication, and transmitting data in JSON Web Tokens (JWTs)."
        },
        {
          title: "How It Works Under the Hood",
          content: "Base64 encoding takes three 8-bit bytes of input data (24 bits total) and splits them into four 6-bit chunks. Each 6-bit chunk maps to one of 64 characters (A-Z, a-z, 0-9, +, and /). Because it maps 3 bytes to 4 characters, <strong>Base64 encoded data is always exactly 33% larger than the original data</strong>."
        },
        {
          title: "URL-Safe Base64",
          content: "Standard Base64 uses the <code>+</code> and <code>/</code> characters, which have special meanings in URLs. URL-safe Base64 swaps these characters for <code>-</code> (minus) and <code>_</code> (underscore), and typically omits the <code>=</code> padding characters, making it safe to include in URL paths and query parameters."
        }
      ]}
    />
    <FaqSection 
      faqs={[
        {
          question: "Is Base64 an encryption method?",
          text: "No. Base64 is an encoding scheme, not encryption. It provides absolutely no security or obfuscation. Anyone who sees a Base64 string can instantly decode it back to the original data. Never use Base64 to secure passwords or sensitive data.",
          answer: "No. Base64 is an encoding scheme, not encryption. It provides absolutely no security or obfuscation. Anyone who sees a Base64 string can instantly decode it back to the original data. Never use Base64 to secure passwords or sensitive data."
        },
        {
          question: "Why is my Base64 output larger than my input?",
          text: "By design, Base64 converts 3 bytes of binary data into 4 characters of text. This means the resulting string will always be about 33% larger than the original input.",
          answer: "By design, Base64 converts 3 bytes of binary data into 4 characters of text. This means the resulting string will always be about 33% larger than the original input."
        },
        {
          question: "Can I encode images to Base64?",
          text: "Yes. In Encode mode, you can drag and drop an image file into the drop zone. The tool will generate a Data URI (e.g., data:image/png;base64,...) that you can paste directly into an HTML <img> tag or a CSS background-image property.",
          answer: "Yes. In Encode mode, you can drag and drop an image file into the drop zone. The tool will generate a Data URI (e.g., <code>data:image/png;base64,...</code>) that you can paste directly into an HTML <code>&lt;img&gt;</code> tag or a CSS background-image property."
        },
        {
          question: "What are the '=' characters at the end of a Base64 string?",
          text: "They are padding characters. Because Base64 processes data in 3-byte blocks, if the input data length is not perfectly divisible by 3, the '=' character is added to pad the output so the decoder knows how many bytes were in the final block.",
          answer: "They are padding characters. Because Base64 processes data in 3-byte blocks, if the input data length is not perfectly divisible by 3, the <code>=</code> character is added to pad the output so the decoder knows how many bytes were in the final block."
        }
      ]}
    />
  </Fragment>

  <script>
    import { copyToClipboard } from '../../lib/clipboard';
    import { downloadFile } from '../../lib/download';
    import { encodeBase64, encodeFileToBase64, decodeBase64 } from '../../tools/base64';

    let mode: 'encode' | 'decode' = 'encode';

    const input = document.getElementById('input') as HTMLTextAreaElement;
    const output = document.getElementById('output') as HTMLTextAreaElement;
    const errorBanner = document.getElementById('errorBanner')!;
    const errorMessage = document.getElementById('errorMessage')!;
    
    const modeEncodeBtn = document.getElementById('modeEncode')!;
    const modeDecodeBtn = document.getElementById('modeDecode')!;
    const urlSafeWrapper = document.getElementById('urlSafeWrapper')!;
    const urlSafeCb = document.getElementById('urlSafe') as HTMLInputElement;
    const fileDropZone = document.getElementById('fileDropZone')!;
    const fileInput = document.getElementById('fileInput') as HTMLInputElement;

    const inputLabel = document.getElementById('inputLabel')!;
    const outputLabel = document.getElementById('outputLabel')!;
    const inputSize = document.getElementById('inputSize')!;
    const outputSize = document.getElementById('outputSize')!;

    const copyBtn = document.getElementById('copyBtn')!;
    const downloadBtn = document.getElementById('downloadBtn')!;

    function formatBytes(bytes: number, decimals = 2) {
      if (!+bytes) return '0 B';
      const k = 1024;
      const dm = decimals < 0 ? 0 : decimals;
      const sizes = ['B', 'KB', 'MB', 'GB', 'TB'];
      const i = Math.floor(Math.log(bytes) / Math.log(k));
      return `${parseFloat((bytes / Math.pow(k, i)).toFixed(dm))} ${sizes[i]}`;
    }

    function setMode(newMode: 'encode' | 'decode') {
      mode = newMode;
      const activeClass = ['bg-accent', 'text-void'];
      const inactiveClass = ['bg-transparent', 'text-text-secondary'];

      if (mode === 'encode') {
        modeEncodeBtn.classList.add(...activeClass);
        modeEncodeBtn.classList.remove(...inactiveClass);
        modeDecodeBtn.classList.add(...inactiveClass);
        modeDecodeBtn.classList.remove(...activeClass);
        
        inputLabel.textContent = 'Text or File to Encode';
        outputLabel.textContent = 'Base64 Output';
        urlSafeWrapper.classList.remove('hidden');
        fileDropZone.classList.remove('hidden');
        input.placeholder = 'Type or paste here...';
      } else {
        modeDecodeBtn.classList.add(...activeClass);
        modeDecodeBtn.classList.remove(...inactiveClass);
        modeEncodeBtn.classList.add(...inactiveClass);
        modeEncodeBtn.classList.remove(...activeClass);
        
        inputLabel.textContent = 'Base64 String to Decode';
        outputLabel.textContent = 'Decoded Text Output';
        urlSafeWrapper.classList.add('hidden');
        fileDropZone.classList.add('hidden');
        input.placeholder = 'Paste Base64 string here...';
      }
      
      processConversion();
    }

    function updateStats() {
      const inBytes = new Blob([input.value]).size;
      inputSize.textContent = formatBytes(inBytes);

      const outBytes = new Blob([output.value]).size;
      if (outBytes > 0) {
        outputSize.textContent = formatBytes(outBytes);
        outputSize.classList.remove('hidden');
      } else {
        outputSize.classList.add('hidden');
      }
    }

    function processConversion() {
      errorBanner.classList.add('hidden');
      const val = input.value;
      
      if (!val) {
        output.value = '';
        updateStats();
        return;
      }

      try {
        if (mode === 'encode') {
          output.value = encodeBase64(val, urlSafeCb.checked);
        } else {
          const res = decodeBase64(val);
          if (res.isValid) {
            output.value = res.text;
          } else {
            output.value = '';
            errorBanner.classList.remove('hidden');
            errorMessage.textContent = res.error || 'Invalid Base64';
          }
        }
      } catch (e: any) {
        output.value = '';
        errorBanner.classList.remove('hidden');
        errorMessage.textContent = e.message;
      }
      
      updateStats();
    }

    modeEncodeBtn.addEventListener('click', () => setMode('encode'));
    modeDecodeBtn.addEventListener('click', () => setMode('decode'));
    urlSafeCb.addEventListener('change', processConversion);
    input.addEventListener('input', processConversion);

    copyBtn.addEventListener('click', () => {
      if (output.value) {
        copyToClipboard(output.value, copyBtn, `
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          Copied!
        `);
      }
    });

    downloadBtn.addEventListener('click', () => {
      if (output.value) {
        const ext = mode === 'encode' ? 'txt' : 'txt';
        downloadFile(output.value, `base64_result.${ext}`, 'text/plain;charset=utf-8;');
      }
    });

    // File Drag & Drop for Encode
    fileDropZone.addEventListener('click', () => fileInput.click());
    
    fileInput.addEventListener('change', async (e) => {
      const file = (e.target as HTMLInputElement).files?.[0];
      if (file && mode === 'encode') {
        try {
          const b64 = await encodeFileToBase64(file);
          output.value = b64;
          input.value = `[File: ${file.name}]`; // Placeholder to show file loaded
          updateStats();
        } catch (err: any) {
          errorBanner.classList.remove('hidden');
          errorMessage.textContent = 'Failed to read file: ' + err.message;
        }
      }
    });

    fileDropZone.addEventListener('dragover', (e) => {
      e.preventDefault();
      fileDropZone.classList.add('border-accent', 'bg-surface/80');
    });
    
    fileDropZone.addEventListener('dragleave', () => {
      fileDropZone.classList.remove('border-accent', 'bg-surface/80');
    });
    
    fileDropZone.addEventListener('drop', async (e) => {
      e.preventDefault();
      fileDropZone.classList.remove('border-accent', 'bg-surface/80');
      
      if (mode !== 'encode') return;
      
      const file = e.dataTransfer?.files[0];
      if (file) {
        try {
          const b64 = await encodeFileToBase64(file);
          output.value = b64;
          input.value = `[File: ${file.name}]`;
          updateStats();
        } catch (err: any) {
          errorBanner.classList.remove('hidden');
          errorMessage.textContent = 'Failed to read file: ' + err.message;
        }
      }
    });

  </script>
</ToolLayout>
