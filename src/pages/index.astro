---
import HubLayout from '../layouts/HubLayout.astro';
import { tools } from '../lib/tool-registry';

const featuredTools = tools.filter(t => t.featured);

const categories = tools.reduce((acc, tool) => {
  if (!acc[tool.category]) {
    acc[tool.category] = [];
  }
  acc[tool.category].push(tool);
  return acc;
}, {} as Record<string, typeof tools>);

const categoryOrder = ['converters', 'formatters', 'dev-tools', 'generators', 'encoders', 'text-tools'];
const sortedCategories = Object.keys(categories).sort((a, b) => {
  return categoryOrder.indexOf(a) - categoryOrder.indexOf(b);
});
---

<HubLayout title="MyToolboxHub — Developer Utility Suite" description="Your premium, blazing-fast developer utility suite. Client-side, secure, and built for performance.">
  <!-- Hero Section -->
  <section class="relative py-24 sm:py-32 overflow-hidden border-b border-border-subtle">
    <div class="absolute inset-0 bg-void">
      <!-- Glow effect -->
      <div class="absolute -top-48 left-1/2 -translate-x-1/2 w-full max-w-3xl h-96 bg-accent/20 blur-[120px] rounded-full pointer-events-none"></div>
    </div>
    
    <div class="relative max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-6xl font-bold tracking-tight text-text-primary mb-6">
        Your Developer Toolbox, <span class="text-accent">Online.</span>
      </h1>
      <p class="text-xl text-text-secondary max-w-2xl mx-auto mb-10">
        Blazing fast, privacy-first, client-side tools designed for modern developers. Zero friction.
      </p>
      
      <!-- Search Bar -->
      <div class="max-w-xl mx-auto relative group">
        <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none">
          <svg class="w-5 h-5 text-text-muted group-focus-within:text-accent transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
        <input 
          type="text" 
          placeholder="Search for tools (e.g., JSON to CSV, Base64)..." 
          class="w-full bg-surface/50 border border-border-strong rounded-full py-4 pl-12 pr-4 text-text-primary placeholder:text-text-muted focus-glow backdrop-blur-sm transition-all"
        >
        <div class="absolute inset-y-0 right-4 flex items-center">
          <kbd class="hidden sm:inline-flex items-center gap-1 font-sans text-xs bg-base border border-border-default px-2 py-1 rounded text-text-secondary">
            ⌘K
          </kbd>
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8 py-16 w-full space-y-24">
    <!-- Featured Tools -->
    <section>
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold text-text-primary flex items-center gap-2">
          <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
          </svg>
          Featured Tools
        </h2>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {featuredTools.map(tool => (
          <a href={`/${tool.slug}`} class="glass p-6 group hover:-translate-y-1 transition-all duration-300 hover:shadow-glow-sm hover:border-accent/40 relative overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-1 bg-accent transform origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-300"></div>
            <div class="flex items-start justify-between mb-4">
              <div class="bg-surface border border-border-subtle p-3 rounded-xl group-hover:bg-accent/10 transition-colors">
                <!-- Icon Placeholder -->
                <svg class="w-6 h-6 text-text-primary group-hover:text-accent transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              </div>
              {tool.status === 'coming-soon' && (
                <span class="text-[10px] uppercase tracking-wider bg-surface border border-border-subtle px-2 py-1 rounded-full text-text-muted">Coming Soon</span>
              )}
            </div>
            <h3 class="text-xl font-semibold text-text-primary mb-2 group-hover:text-accent transition-colors">{tool.name}</h3>
            <p class="text-text-secondary text-sm leading-relaxed">{tool.description}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- All Tools by Category -->
    <section>
      <h2 class="text-2xl font-bold text-text-primary mb-12">All Tools Directory</h2>
      <div class="space-y-16">
        {sortedCategories.map(category => (
          <div>
            <h3 class="text-sm font-bold text-text-primary uppercase tracking-widest mb-6 flex items-center gap-4">
              {category.replace('-', ' ')}
              <div class="flex-1 h-px bg-border-subtle"></div>
            </h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
              {categories[category].map(tool => (
                <a href={`/${tool.slug}`} class="group flex flex-col p-4 bg-surface/30 border border-border-subtle rounded-xl hover:bg-surface hover:border-border-default transition-all">
                  <div class="flex items-center gap-3 mb-2">
                    <span class="text-text-primary font-medium group-hover:text-accent transition-colors">{tool.shortName || tool.name}</span>
                    {tool.status === 'coming-soon' && (
                      <span class="ml-auto text-[10px] uppercase tracking-wider bg-void border border-border-subtle px-1.5 py-0.5 rounded text-text-muted">Soon</span>
                    )}
                  </div>
                  <p class="text-xs text-text-muted line-clamp-2">{tool.description}</p>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  </div>
</HubLayout>
