---
import HubLayout from '../layouts/HubLayout.astro';
import { tools } from '../lib/tool-registry';

const featuredTools = tools.filter(t => t.featured);
const stableTools = tools.filter(t => t.status === 'stable');

const categories = tools.reduce((acc, tool) => {
  if (!acc[tool.category]) {
    acc[tool.category] = [];
  }
  acc[tool.category].push(tool);
  return acc;
}, {} as Record<string, typeof tools>);

const categoryOrder = ['converters', 'formatters', 'dev-tools', 'generators', 'encoders', 'text-tools', 'cleaners'];
const sortedCategories = Object.keys(categories).sort((a, b) => {
  return categoryOrder.indexOf(a) - categoryOrder.indexOf(b);
});
---

<HubLayout title="MyToolboxHub — Developer Utility Suite" description="Your premium, blazing-fast developer utility suite. Client-side, secure, and built for performance.">
  <!-- Hero Section -->
  <section class="relative min-h-[85vh] flex items-center justify-center overflow-hidden border-b border-border-subtle" id="heroSection">
    
    <!-- Animated Canvas Background -->
    <canvas id="heroCanvas" class="absolute inset-0 w-full h-full pointer-events-none"></canvas>

    <!-- Accent Glow Orbs -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="absolute -top-32 left-1/4 w-[600px] h-[600px] bg-accent/8 rounded-full blur-[150px] animate-pulse-slow"></div>
      <div class="absolute -bottom-48 right-1/4 w-[500px] h-[500px] bg-accent/6 rounded-full blur-[130px] animate-pulse-slow" style="animation-delay: 2s;"></div>
    </div>

    <!-- Grid overlay -->
    <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: linear-gradient(rgba(255,255,255,.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.1) 1px, transparent 1px); background-size: 60px 60px;"></div>

    <!-- Content -->
    <div class="relative z-10 max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      
      <!-- Eyebrow -->
      <div class="inline-flex items-center gap-2 bg-surface/40 backdrop-blur-sm border border-border-subtle rounded-full px-4 py-1.5 mb-8 animate-fade-in-down" style="animation-delay: 0.1s;">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-accent"></span>
        </span>
        <span class="text-xs font-medium text-text-secondary tracking-wide">{stableTools.length} tools live — 100% client-side</span>
      </div>

      <!-- Headline -->
      <h1 class="hero-title text-5xl sm:text-7xl lg:text-8xl font-bold tracking-tighter text-text-primary mb-6 leading-[0.9]">
        <span class="block animate-fade-in-up" style="animation-delay: 0.2s;">Your Developer</span>
        <span class="block animate-fade-in-up" style="animation-delay: 0.35s;">Toolbox, <span class="text-accent relative inline-block">Online<span class="absolute -bottom-2 left-0 w-full h-[3px] bg-accent/60 rounded-full"></span></span></span>
      </h1>

      <!-- Subtitle -->
      <p class="text-lg sm:text-xl text-text-secondary max-w-2xl mx-auto mb-12 animate-fade-in-up leading-relaxed" style="animation-delay: 0.5s;">
        Blazing fast, privacy-first utilities designed for modern developers.<br class="hidden sm:inline" /> Zero friction. Zero dependencies. Zero data leaves your browser.
      </p>
      
      <!-- CTA Row -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-in-up" style="animation-delay: 0.65s;">
        <button 
          id="heroSearchBtn" 
          class="group flex items-center gap-3 px-6 py-3.5 bg-accent text-void font-bold rounded-xl hover:bg-accent-hover transition-all shadow-lg shadow-accent/20 hover:shadow-accent/40 hover:-translate-y-0.5 focus-glow"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          Search Tools
          <kbd class="hidden sm:inline-flex items-center text-[10px] bg-void/20 px-1.5 py-0.5 rounded font-mono font-normal">⌘K</kbd>
        </button>
        <a href="#directory" class="flex items-center gap-2 px-6 py-3.5 text-text-secondary font-medium rounded-xl border border-border-subtle hover:border-border-default hover:text-text-primary hover:bg-surface/50 transition-all">
          Browse All Tools
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </a>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce hidden md:block" style="animation-delay: 1.5s;">
        <div class="w-6 h-10 rounded-full border-2 border-border-default flex items-start justify-center p-1.5">
          <div class="w-1.5 h-3 rounded-full bg-text-muted animate-scroll-dot"></div>
        </div>
      </div>
    </div>

    <!-- Mouse-tracking glow -->
    <div id="mouseGlow" class="absolute w-[500px] h-[500px] rounded-full pointer-events-none opacity-0 transition-opacity duration-500" style="background: radial-gradient(circle, rgba(var(--color-accent-rgb, 99, 102, 241), 0.08), transparent 70%); transform: translate(-50%, -50%);"></div>
  </section>

  <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8 py-16 w-full space-y-24">
    <!-- Featured Tools -->
    <section>
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold text-text-primary flex items-center gap-2">
          <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
          </svg>
          Featured Tools
        </h2>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {featuredTools.map(tool => (
          <a href={`/${tool.slug}`} class="glass p-6 group hover:-translate-y-1 transition-all duration-300 hover:shadow-glow-sm hover:border-accent/40 relative overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-1 bg-accent transform origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-300"></div>
            <div class="flex items-start justify-between mb-4">
              <div class="bg-surface border border-border-subtle p-3 rounded-xl group-hover:bg-accent/10 transition-colors">
                <svg class="w-6 h-6 text-text-primary group-hover:text-accent transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              </div>
              {tool.status === 'coming-soon' && (
                <span class="text-[10px] uppercase tracking-wider bg-surface border border-border-subtle px-2 py-1 rounded-full text-text-muted">Coming Soon</span>
              )}
            </div>
            <h3 class="text-xl font-semibold text-text-primary mb-2 group-hover:text-accent transition-colors">{tool.name}</h3>
            <p class="text-text-secondary text-sm leading-relaxed">{tool.description}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- All Tools by Category -->
    <section id="directory">
      <h2 class="text-2xl font-bold text-text-primary mb-12">All Tools Directory</h2>
      <div class="space-y-16">
        {sortedCategories.map(category => (
          <div>
            <h3 class="text-sm font-bold text-text-primary uppercase tracking-widest mb-6 flex items-center gap-4">
              {category.replace('-', ' ')}
              <div class="flex-1 h-px bg-border-subtle"></div>
            </h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
              {categories[category].map(tool => (
                <a href={`/${tool.slug}`} class="group flex flex-col p-4 bg-surface/30 border border-border-subtle rounded-xl hover:bg-surface hover:border-border-default transition-all">
                  <div class="flex items-center gap-3 mb-2">
                    <span class="text-text-primary font-medium group-hover:text-accent transition-colors">{tool.shortName || tool.name}</span>
                    {tool.status === 'coming-soon' && (
                      <span class="ml-auto text-[10px] uppercase tracking-wider bg-void border border-border-subtle px-1.5 py-0.5 rounded text-text-muted">Soon</span>
                    )}
                  </div>
                  <p class="text-xs text-text-muted line-clamp-2">{tool.description}</p>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  </div>

  <!-- Hero Canvas Animation -->
  <script>
    // Wire up hero search button to the global search modal
    const heroSearchBtn = document.getElementById('heroSearchBtn');
    if (heroSearchBtn) {
      heroSearchBtn.addEventListener('click', () => {
        // Trigger Cmd+K programmatically to open search modal
        document.dispatchEvent(new KeyboardEvent('keydown', { key: 'k', metaKey: true, ctrlKey: true, bubbles: true }));
      });
    }

    // Mouse tracking glow
    const heroSection = document.getElementById('heroSection');
    const mouseGlow = document.getElementById('mouseGlow');
    if (heroSection && mouseGlow) {
      heroSection.addEventListener('mousemove', (e) => {
        const rect = heroSection.getBoundingClientRect();
        mouseGlow.style.left = (e.clientX - rect.left) + 'px';
        mouseGlow.style.top = (e.clientY - rect.top) + 'px';
        mouseGlow.style.opacity = '1';
      });
      heroSection.addEventListener('mouseleave', () => {
        mouseGlow.style.opacity = '0';
      });
    }

    // Particle Grid Canvas (inspired by fabric.vc mesh)
    const canvas = document.getElementById('heroCanvas') as HTMLCanvasElement;
    if (canvas) {
      const ctx = canvas.getContext('2d')!;
      let animId: number;
      let mouse = { x: -9999, y: -9999 };
      
      interface Point {
        x: number;
        y: number;
        baseX: number;
        baseY: number;
        vx: number;
        vy: number;
      }
      
      let points: Point[] = [];
      let cols = 0;
      let rows = 0;
      const spacing = 50;
      const interactionRadius = 120;
      const returnForce = 0.04;
      const friction = 0.85;

      function resize() {
        canvas.width = canvas.offsetWidth * window.devicePixelRatio;
        canvas.height = canvas.offsetHeight * window.devicePixelRatio;
        ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
        initGrid();
      }

      function initGrid() {
        const w = canvas.offsetWidth;
        const h = canvas.offsetHeight;
        cols = Math.ceil(w / spacing) + 1;
        rows = Math.ceil(h / spacing) + 1;
        points = [];

        for (let r = 0; r < rows; r++) {
          for (let c = 0; c < cols; c++) {
            points.push({
              x: c * spacing,
              y: r * spacing,
              baseX: c * spacing,
              baseY: r * spacing,
              vx: 0,
              vy: 0,
            });
          }
        }
      }

      function getIdx(r: number, c: number) {
        if (r < 0 || r >= rows || c < 0 || c >= cols) return -1;
        return r * cols + c;
      }

      function draw() {
        const w = canvas.offsetWidth;
        const h = canvas.offsetHeight;
        ctx.clearRect(0, 0, w, h);

        // Update points
        for (const p of points) {
          // Mouse repulsion
          const dx = p.x - mouse.x;
          const dy = p.y - mouse.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          
          if (dist < interactionRadius && dist > 0) {
            const force = (1 - dist / interactionRadius) * 3;
            p.vx += (dx / dist) * force;
            p.vy += (dy / dist) * force;
          }

          // Return to base
          p.vx += (p.baseX - p.x) * returnForce;
          p.vy += (p.baseY - p.y) * returnForce;

          p.vx *= friction;
          p.vy *= friction;

          p.x += p.vx;
          p.y += p.vy;
        }

        // Draw connections
        for (let r = 0; r < rows; r++) {
          for (let c = 0; c < cols; c++) {
            const idx = getIdx(r, c);
            if (idx === -1) continue;
            const p = points[idx];

            // Calculate displacement for opacity
            const dispX = p.x - p.baseX;
            const dispY = p.y - p.baseY;
            const displacement = Math.sqrt(dispX * dispX + dispY * dispY);
            const baseAlpha = 0.06;
            const activeAlpha = Math.min(0.35, baseAlpha + displacement * 0.012);

            // Right neighbor
            const rIdx = getIdx(r, c + 1);
            if (rIdx !== -1) {
              const rp = points[rIdx];
              ctx.beginPath();
              ctx.moveTo(p.x, p.y);
              ctx.lineTo(rp.x, rp.y);
              ctx.strokeStyle = `rgba(255, 255, 255, ${activeAlpha})`;
              ctx.lineWidth = 0.5;
              ctx.stroke();
            }

            // Bottom neighbor
            const bIdx = getIdx(r + 1, c);
            if (bIdx !== -1) {
              const bp = points[bIdx];
              ctx.beginPath();
              ctx.moveTo(p.x, p.y);
              ctx.lineTo(bp.x, bp.y);
              ctx.strokeStyle = `rgba(255, 255, 255, ${activeAlpha})`;
              ctx.lineWidth = 0.5;
              ctx.stroke();
            }

            // Draw node dot
            const dotAlpha = Math.min(0.5, 0.1 + displacement * 0.02);
            ctx.beginPath();
            ctx.arc(p.x, p.y, 1.2 + displacement * 0.04, 0, Math.PI * 2);
            ctx.fillStyle = `rgba(255, 255, 255, ${dotAlpha})`;
            ctx.fill();
          }
        }

        animId = requestAnimationFrame(draw);
      }

      // Mouse events
      const heroSect = document.getElementById('heroSection')!;
      heroSect.addEventListener('mousemove', (e) => {
        const rect = canvas.getBoundingClientRect();
        mouse.x = e.clientX - rect.left;
        mouse.y = e.clientY - rect.top;
      });
      heroSect.addEventListener('mouseleave', () => {
        mouse.x = -9999;
        mouse.y = -9999;
      });

      // Init
      window.addEventListener('resize', resize);
      resize();
      draw();

      // Cleanup on navigation
      document.addEventListener('astro:before-preparation', () => {
        cancelAnimationFrame(animId);
      });
    }
  </script>

  <style>
    @keyframes fade-in-up {
      from { opacity: 0; transform: translateY(24px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes fade-in-down {
      from { opacity: 0; transform: translateY(-12px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes scroll-dot {
      0%, 100% { opacity: 0; transform: translateY(0); }
      50% { opacity: 1; transform: translateY(6px); }
    }
    @keyframes pulse-slow {
      0%, 100% { opacity: 0.6; transform: scale(1); }
      50% { opacity: 1; transform: scale(1.05); }
    }

    .animate-fade-in-up {
      opacity: 0;
      animation: fade-in-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    .animate-fade-in-down {
      opacity: 0;
      animation: fade-in-down 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    .animate-scroll-dot {
      animation: scroll-dot 2s ease-in-out infinite;
    }
    .animate-pulse-slow {
      animation: pulse-slow 6s ease-in-out infinite;
    }

    .hero-title {
      letter-spacing: -0.04em;
    }
  </style>
</HubLayout>
