---
import ToolLayout from '../../layouts/ToolLayout.astro';
import HowToSection from '../../components/seo/HowToSection.astro';
import FaqSection from '../../components/seo/FaqSection.astro';
import TechnicalExplainer from '../../components/seo/TechnicalExplainer.astro';
import { tools } from '../../lib/tool-registry';

const tool = tools.find(t => t.id === 'json-to-csv')!;
---

<ToolLayout tool={tool}>
  <div class="space-y-6">
    <!-- Controls -->
    <div class="glass p-4 flex flex-wrap gap-6 items-center">
      <div class="flex items-center gap-2">
        <label for="delimiter" class="text-sm font-medium text-text-secondary">Delimiter</label>
        <select id="delimiter" class="bg-surface border border-border-default rounded-md px-2 py-1 text-sm text-text-primary focus-glow">
          <option value=",">Comma (,)</option>
          <option value="\t">Tab</option>
          <option value=";">Semicolon (;)</option>
        </select>
      </div>
      
      <div class="flex items-center gap-2">
        <input type="checkbox" id="includeHeaders" checked class="w-4 h-4 rounded border-border-default bg-surface text-accent focus-glow" />
        <label for="includeHeaders" class="text-sm font-medium text-text-secondary">Include Headers</label>
      </div>

      <div class="flex items-center gap-2">
        <input type="checkbox" id="flattenObjects" checked class="w-4 h-4 rounded border-border-default bg-surface text-accent focus-glow" />
        <label for="flattenObjects" class="text-sm font-medium text-text-secondary">Flatten Objects</label>
      </div>
    </div>

    <!-- Error Banner -->
    <div id="errorBanner" class="hidden bg-error/10 border border-error/30 text-error px-4 py-3 rounded-lg text-sm flex items-start gap-3 animate-fade-in-down">
      <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <div>
        <strong class="block font-semibold mb-1">Invalid JSON</strong>
        <span id="errorMessage"></span>
      </div>
    </div>

    <!-- Layout Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      
      <!-- Input Panel -->
      <div class="flex flex-col h-[500px]">
        <div class="flex justify-between items-center mb-2">
          <label for="jsonInput" class="text-sm font-semibold text-text-primary">Input JSON</label>
          <button id="formatBtn" class="text-xs text-accent hover:text-accent-hover transition-colors font-medium">Format</button>
        </div>
        <textarea 
          id="jsonInput" 
          class="flex-1 bg-surface/50 border border-border-subtle rounded-xl p-4 font-mono text-sm text-text-primary resize-none focus-glow transition-colors"
          placeholder="Paste JSON here or drag and drop a file..."
          spellcheck="false"
        ></textarea>
      </div>

      <!-- Output Panel -->
      <div class="flex flex-col h-[500px]">
        <div class="flex justify-between items-center mb-2">
          <label for="csvOutput" class="text-sm font-semibold text-text-primary">Output CSV</label>
          <div class="flex gap-3">
            <button id="copyBtn" class="text-xs text-accent hover:text-accent-hover transition-colors flex items-center gap-1 font-medium">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
              Copy
            </button>
            <button id="downloadBtn" class="text-xs text-accent hover:text-accent-hover transition-colors flex items-center gap-1 font-medium">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
              Download
            </button>
          </div>
        </div>
        <textarea 
          id="csvOutput" 
          class="flex-1 bg-void border border-border-subtle rounded-xl p-4 font-mono text-sm text-text-secondary resize-none focus-glow"
          placeholder="CSV output will appear here..."
          readonly
        ></textarea>
      </div>
    </div>
  </div>

  <Fragment slot="content">
    <HowToSection />
    <TechnicalExplainer />
    <FaqSection />
  </Fragment>

  <script>
    import { validateJson, convertJsonToCsv } from '../../tools/json-to-csv';

    const input = document.getElementById('jsonInput') as HTMLTextAreaElement;
    const output = document.getElementById('csvOutput') as HTMLTextAreaElement;
    const errorBanner = document.getElementById('errorBanner')!;
    const errorMessage = document.getElementById('errorMessage')!;
    const delimiterSelect = document.getElementById('delimiter') as HTMLSelectElement;
    const includeHeadersCb = document.getElementById('includeHeaders') as HTMLInputElement;
    const flattenObjectsCb = document.getElementById('flattenObjects') as HTMLInputElement;
    const formatBtn = document.getElementById('formatBtn')!;
    const copyBtn = document.getElementById('copyBtn')!;
    const downloadBtn = document.getElementById('downloadBtn')!;

    function processConversion() {
      const val = input.value;
      if (!val.trim()) {
        output.value = '';
        errorBanner.classList.add('hidden');
        return;
      }

      const validation = validateJson(val);
      if (!validation.valid) {
        errorBanner.classList.remove('hidden');
        errorMessage.textContent = validation.error?.message || 'Invalid JSON syntax';
        return;
      }

      errorBanner.classList.add('hidden');

      const delimiter = delimiterSelect.value;
      const includeHeaders = includeHeadersCb.checked;
      const flattenObjects = flattenObjectsCb.checked;

      try {
        const csv = convertJsonToCsv(validation.data, { delimiter, includeHeaders, flattenObjects });
        output.value = csv;
      } catch (err: any) {
        errorBanner.classList.remove('hidden');
        errorMessage.textContent = 'Conversion error: ' + err.message;
      }
    }

    input.addEventListener('input', processConversion);
    delimiterSelect.addEventListener('change', processConversion);
    includeHeadersCb.addEventListener('change', processConversion);
    flattenObjectsCb.addEventListener('change', processConversion);

    formatBtn.addEventListener('click', () => {
      try {
        const parsed = JSON.parse(input.value);
        input.value = JSON.stringify(parsed, null, 2);
        processConversion();
      } catch (e) {
        // Ignored during format
      }
    });

    copyBtn.addEventListener('click', async () => {
      if (!output.value) return;
      try {
        await navigator.clipboard.writeText(output.value);
        const originalText = copyBtn.innerHTML;
        copyBtn.innerHTML = 'Copied!';
        setTimeout(() => copyBtn.innerHTML = originalText, 2000);
      } catch (err) {
        alert('Failed to copy text');
      }
    });

    downloadBtn.addEventListener('click', () => {
      if (!output.value) return;
      const blob = new Blob([output.value], { type: 'text/csv;charset=utf-8;' });
      const url = URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.setAttribute('href', url);
      link.setAttribute('download', 'data.csv');
      link.style.visibility = 'hidden';
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
    });

    // Handle Drag & Drop
    input.addEventListener('dragover', (e) => {
      e.preventDefault();
      input.classList.add('border-accent', 'bg-surface/80');
    });
    input.addEventListener('dragleave', () => {
      input.classList.remove('border-accent', 'bg-surface/80');
    });
    input.addEventListener('drop', (e) => {
      e.preventDefault();
      input.classList.remove('border-accent', 'bg-surface/80');
      if (e.dataTransfer?.files && e.dataTransfer.files.length > 0) {
        const file = e.dataTransfer.files[0];
        const reader = new FileReader();
        reader.onload = (event) => {
          input.value = event.target?.result as string;
          processConversion();
        };
        reader.readAsText(file);
      }
    });
  </script>
</ToolLayout>
