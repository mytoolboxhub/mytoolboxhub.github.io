---
import ToolLayout from '../../layouts/ToolLayout.astro';
import HowToSection from '../../components/seo/HowToSection.astro';
import FaqSection from '../../components/seo/FaqSection.astro';
import TechnicalExplainer from '../../components/seo/TechnicalExplainer.astro';
import { tools } from '../../lib/tool-registry';

const tool = tools.find(t => t.id === 'json-to-csv')!;
---

<ToolLayout tool={tool}>
  <div class="space-y-6">
    <!-- Controls -->
    <div class="glass p-4 flex flex-wrap gap-6 items-center">
      <div class="flex items-center gap-2">
        <label for="delimiter" class="text-sm font-medium text-text-secondary">Delimiter</label>
        <select id="delimiter" class="bg-surface border border-border-default rounded-md px-2 py-1 text-sm text-text-primary focus-glow">
          <option value=",">Comma (,)</option>
          <option value="\t">Tab</option>
          <option value=";">Semicolon (;)</option>
        </select>
      </div>
      
      <div class="flex items-center gap-2">
        <input type="checkbox" id="includeHeaders" checked class="w-4 h-4 rounded border-border-default bg-surface text-accent focus-glow" />
        <label for="includeHeaders" class="text-sm font-medium text-text-secondary">Include Headers</label>
      </div>

      <div class="flex items-center gap-2">
        <input type="checkbox" id="flattenObjects" checked class="w-4 h-4 rounded border-border-default bg-surface text-accent focus-glow" />
        <label for="flattenObjects" class="text-sm font-medium text-text-secondary">Flatten Objects</label>
      </div>
    </div>

    <!-- Error Banner -->
    <div id="errorBanner" class="hidden bg-error/10 border border-error/30 text-error px-4 py-3 rounded-lg text-sm flex items-start gap-3 animate-fade-in-down">
      <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <div>
        <strong class="block font-semibold mb-1">Invalid JSON</strong>
        <span id="errorMessage"></span>
      </div>
    </div>

    <!-- Layout Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      
      <!-- Input Panel -->
      <div class="flex flex-col h-[500px]">
        <div class="flex justify-between items-center mb-2">
          <label for="jsonInput" class="text-sm font-semibold text-text-primary">Input JSON</label>
          <button id="formatBtn" class="text-xs text-accent hover:text-accent-hover transition-colors font-medium">Format</button>
        </div>
        <textarea 
          id="jsonInput" 
          class="flex-1 bg-surface/50 border border-border-subtle rounded-xl p-4 font-mono text-sm text-text-primary resize-none focus-glow transition-colors"
          placeholder="Paste JSON here or drag and drop a file..."
          spellcheck="false"
        ></textarea>
      </div>

      <!-- Output Panel -->
      <div class="flex flex-col h-[500px]">
        <div class="flex justify-between items-center mb-2">
          <label for="csvOutput" class="text-sm font-semibold text-text-primary">Output CSV</label>
          <div class="flex gap-3">
            <button id="copyBtn" class="text-xs text-accent hover:text-accent-hover transition-colors flex items-center gap-1 font-medium">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
              Copy
            </button>
            <button id="downloadBtn" class="text-xs text-accent hover:text-accent-hover transition-colors flex items-center gap-1 font-medium">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
              Download
            </button>
          </div>
        </div>
        <textarea 
          id="csvOutput" 
          class="flex-1 bg-void border border-border-subtle rounded-xl p-4 font-mono text-sm text-text-secondary resize-none focus-glow"
          placeholder="CSV output will appear here..."
          readonly
        ></textarea>
      </div>
    </div>
  </div>

  <Fragment slot="content">
    <HowToSection 
      title="How to Convert JSON to CSV"
      steps={[
        {
          name: "Paste or Upload Your JSON Data",
          text: "Paste your JSON directly into the editor on the left, or drag and drop a .json file onto the upload area. The converter accepts arrays of objects, nested objects, and mixed-type datasets.",
          description: "Paste your JSON directly into the editor on the left, or drag and drop a <code class=\"bg-base px-1.5 py-0.5 rounded text-text-primary\">.json</code> file onto the upload area. The converter accepts arrays of objects, nested objects, and mixed-type datasets."
        },
        {
          name: "Configure Conversion Options",
          text: "Choose your preferred delimiter (comma, tab, or semicolon), toggle column headers on or off, and select whether to flatten nested objects into dot-notation columns.",
          description: "Choose your preferred delimiter (comma, tab, or semicolon), toggle column headers on or off, and select whether to flatten nested objects into dot-notation columns (e.g., <code class=\"bg-base px-1.5 py-0.5 rounded text-text-primary\">address.city</code>)."
        },
        {
          name: "Preview & Validate",
          text: "Click Convert to see an instant preview of your CSV data in the interactive grid below. The converter validates your JSON syntax in real-time and highlights any errors with line numbers.",
          description: "Click \"Convert\" to see an instant preview of your CSV data in the interactive grid below. The converter validates your JSON syntax in real-time and highlights any errors with line numbers."
        },
        {
          name: "Download or Copy",
          text: "Click Download .csv to save the file to your device, or use Copy to Clipboard to paste it directly into Excel, Google Sheets, or your database import tool.",
          description: "Click \"Download .csv\" to save the file to your device, or use \"Copy to Clipboard\" to paste it directly into Excel, Google Sheets, or your database import tool."
        }
      ]}
    />
    <TechnicalExplainer 
      title="Understanding JSON and CSV: Formats, Use Cases, and Trade-offs"
      sections={[
        {
          title: "What is JSON?",
          content: "JSON (JavaScript Object Notation) is a lightweight data interchange format that is easy for humans to read and write, and easy for machines to parse and generate. It is built on two structures: a collection of name/value pairs (often realized as an object, record, struct, dictionary, hash table, keyed list, or associative array), and an ordered list of values (an array, vector, list, or sequence). Because it supports nested structures, it's the dominant format for web APIs."
        },
        {
          title: "What is CSV?",
          content: "CSV (Comma-Separated Values) is a plain-text tabular format. It stores tabular data (numbers and text) in plain text, where each line of the file is a data record, and each record consists of one or more fields, separated by commas. It is widely supported by consumer, business, and scientific applications (like Microsoft Excel, Google Sheets, and databases)."
        },
        {
          title: "When Should You Convert JSON to CSV?",
          content: "<ul class=\"space-y-2 list-disc pl-5 mb-4 marker:text-accent\"><li><strong class=\"text-text-primary\">Spreadsheet analysis:</strong> Import API data into Excel or Google Sheets for financial modeling, charting, or pivot tables.</li><li><strong class=\"text-text-primary\">Database imports:</strong> Bulk-load data into SQL databases via CSV, which is often much faster and natively supported by tools like PostgreSQL's <code>COPY</code> command.</li><li><strong class=\"text-text-primary\">Reporting:</strong> Generate human-readable tabular reports from complex, nested API responses.</li><li><strong class=\"text-text-primary\">Legacy system integration:</strong> Interface with older business systems that only accept flat CSV files.</li></ul>"
        },
        {
          title: "How This Converter Handles Edge Cases",
          content: "<ul class=\"space-y-2 list-disc pl-5 mb-4 marker:text-accent\"><li><strong class=\"text-text-primary\">Nested Objects:</strong> Flattened using dot-notation (`user.address.city`), making them perfectly suited for column-based databases.</li><li><strong class=\"text-text-primary\">Arrays:</strong> Serialized as quoted strings to preserve their content without breaking the CSV structure.</li><li><strong class=\"text-text-primary\">Null/Undefined:</strong> Rendered as empty fields to maintain column alignment.</li><li><strong class=\"text-text-primary\">Mixed Types:</strong> Coerced to strings with type preservation where possible.</li></ul>"
        }
      ]}
    />
    <FaqSection 
      faqs={[
        {
          question: "Is my data safe? Does the converter send data to a server?",
          text: "No. This converter runs entirely in your browser using client-side JavaScript. Your data never leaves your device — nothing is uploaded, stored, or transmitted.",
          answer: "No. This converter runs entirely in your browser using client-side JavaScript. Your data never leaves your device — nothing is uploaded, stored, or transmitted."
        },
        {
          question: "What is the maximum file size I can convert?",
          text: "There is no hard limit, but for optimal performance we recommend files under 50 MB. Larger files are processed efficiently, but very large datasets may temporarily slow down your browser.",
          answer: "There is no hard limit, but for optimal performance we recommend files under 50 MB. Larger files are processed efficiently, but very large datasets may temporarily slow down your browser."
        },
        {
          question: "Can I convert nested JSON objects?",
          text: "Yes. The converter automatically detects nested structures and flattens them using dot-notation (e.g., user.address.city becomes a column).",
          answer: "Yes. The converter automatically detects nested structures and flattens them using dot-notation (e.g., <code class=\"text-sm bg-surface px-1 py-0.5 rounded\">user.address.city</code> becomes a column)."
        },
        {
          question: "Does it work with JSON arrays of different structures?",
          text: "Yes. The schema detector analyzes all objects in the array and creates a superset of all unique keys. Objects missing a key will have an empty value in that column.",
          answer: "Yes. The schema detector analyzes all objects in the array and creates a superset of all unique keys. Objects missing a key will have an empty value in that column."
        },
        {
          question: "Can I use a custom delimiter instead of commas?",
          text: "Yes. You can choose between comma (,), tab, or semicolon (;) as your delimiter in the options bar.",
          answer: "Yes. You can choose between comma (,), tab, or semicolon (;) as your delimiter in the options bar."
        }
      ]}
    />
  </Fragment>

  <script>
    import { validateJson } from '../../lib/json-validator';
    import { copyToClipboard } from '../../lib/clipboard';
    import { downloadFile } from '../../lib/download';
    import { convertJsonToCsv } from '../../tools/json-to-csv';

    const input = document.getElementById('jsonInput') as HTMLTextAreaElement;
    const output = document.getElementById('csvOutput') as HTMLTextAreaElement;
    const errorBanner = document.getElementById('errorBanner')!;
    const errorMessage = document.getElementById('errorMessage')!;
    const delimiterSelect = document.getElementById('delimiter') as HTMLSelectElement;
    const includeHeadersCb = document.getElementById('includeHeaders') as HTMLInputElement;
    const flattenObjectsCb = document.getElementById('flattenObjects') as HTMLInputElement;
    const formatBtn = document.getElementById('formatBtn')!;
    const copyBtn = document.getElementById('copyBtn')!;
    const downloadBtn = document.getElementById('downloadBtn')!;

    function processConversion() {
      const val = input.value;
      if (!val.trim()) {
        output.value = '';
        errorBanner.classList.add('hidden');
        return;
      }

      const validation = validateJson(val);
      if (!validation.valid) {
        errorBanner.classList.remove('hidden');
        errorMessage.textContent = validation.error?.message || 'Invalid JSON syntax';
        return;
      }

      errorBanner.classList.add('hidden');

      const delimiter = delimiterSelect.value;
      const includeHeaders = includeHeadersCb.checked;
      const flattenObjects = flattenObjectsCb.checked;

      try {
        const csv = convertJsonToCsv(validation.data, { delimiter, includeHeaders, flattenObjects });
        output.value = csv;
      } catch (err: any) {
        errorBanner.classList.remove('hidden');
        errorMessage.textContent = 'Conversion error: ' + err.message;
      }
    }

    input.addEventListener('input', processConversion);
    delimiterSelect.addEventListener('change', processConversion);
    includeHeadersCb.addEventListener('change', processConversion);
    flattenObjectsCb.addEventListener('change', processConversion);

    formatBtn.addEventListener('click', () => {
      try {
        const parsed = JSON.parse(input.value);
        input.value = JSON.stringify(parsed, null, 2);
        processConversion();
      } catch (e) {
        // Ignored during format
      }
    });

    copyBtn.addEventListener('click', () => {
      if (output.value) {
        copyToClipboard(output.value, copyBtn, `
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          Copied!
        `);
      }
    });

    downloadBtn.addEventListener('click', () => {
      if (output.value) {
        downloadFile(output.value, 'data.csv', 'text/csv;charset=utf-8;');
      }
    });

    // Handle Drag & Drop
    input.addEventListener('dragover', (e) => {
      e.preventDefault();
      input.classList.add('border-accent', 'bg-surface/80');
    });
    input.addEventListener('dragleave', () => {
      input.classList.remove('border-accent', 'bg-surface/80');
    });
    input.addEventListener('drop', (e) => {
      e.preventDefault();
      input.classList.remove('border-accent', 'bg-surface/80');
      if (e.dataTransfer?.files && e.dataTransfer.files.length > 0) {
        const file = e.dataTransfer.files[0];
        const reader = new FileReader();
        reader.onload = (event) => {
          input.value = event.target?.result as string;
          processConversion();
        };
        reader.readAsText(file);
      }
    });
  </script>
</ToolLayout>
