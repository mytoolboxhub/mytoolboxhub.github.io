---
import ToolLayout from '../../layouts/ToolLayout.astro';
import HowToSection from '../../components/seo/HowToSection.astro';
import FaqSection from '../../components/seo/FaqSection.astro';
import TechnicalExplainer from '../../components/seo/TechnicalExplainer.astro';
import { tools } from '../../lib/tool-registry';

const tool = tools.find(t => t.id === 'list-cleaner')!;
---

<ToolLayout tool={tool}>
  <div class="space-y-6">
    
    <!-- Controls Bar -->
    <div class="glass p-6 rounded-2xl">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        
        <!-- Deduplicate & Trim -->
        <div class="space-y-3">
          <span class="text-xs font-bold uppercase tracking-wider text-text-muted mb-2 block">Cleaning</span>
          <label class="flex items-center gap-2 cursor-pointer group">
            <input type="checkbox" id="cbDedup" checked class="w-4 h-4 rounded border-border-default bg-surface text-accent focus-glow" />
            <span class="text-sm text-text-primary group-hover:text-accent transition-colors">Remove Duplicates</span>
          </label>
          <label class="flex items-center gap-2 cursor-pointer group ml-6">
            <input type="checkbox" id="cbCase" class="w-4 h-4 rounded border-border-default bg-surface text-accent focus-glow" />
            <span class="text-xs text-text-secondary group-hover:text-accent transition-colors">Case Insensitive</span>
          </label>
          <label class="flex items-center gap-2 cursor-pointer group">
            <input type="checkbox" id="cbTrim" checked class="w-4 h-4 rounded border-border-default bg-surface text-accent focus-glow" />
            <span class="text-sm text-text-primary group-hover:text-accent transition-colors">Trim Whitespace</span>
          </label>
          <label class="flex items-center gap-2 cursor-pointer group">
            <input type="checkbox" id="cbEmpty" checked class="w-4 h-4 rounded border-border-default bg-surface text-accent focus-glow" />
            <span class="text-sm text-text-primary group-hover:text-accent transition-colors">Remove Empty Lines</span>
          </label>
        </div>

        <!-- Sorting -->
        <div class="space-y-3">
          <span class="text-xs font-bold uppercase tracking-wider text-text-muted mb-2 block">Sorting</span>
          <select id="sortMode" class="w-full bg-surface border border-border-default rounded-md px-3 py-2 text-sm text-text-primary focus-glow outline-none">
            <option value="none">No Sorting (Original Order)</option>
            <option value="alpha-asc">Alphabetical (A → Z)</option>
            <option value="alpha-desc">Alphabetical (Z → A)</option>
            <option value="length-asc">By Length (Short → Long)</option>
            <option value="length-desc">By Length (Long → Short)</option>
            <option value="numeric">Numerical Order</option>
            <option value="shuffle">Random Shuffle</option>
          </select>
        </div>

        <!-- Pre/Suffix -->
        <div class="space-y-3">
          <span class="text-xs font-bold uppercase tracking-wider text-text-muted mb-2 block">Formatting</span>
          <div class="flex flex-col gap-1">
            <input type="text" id="prefixInput" placeholder="Add Prefix..." class="bg-surface border border-border-default rounded px-3 py-1.5 text-sm text-text-primary focus-glow outline-none" />
          </div>
          <div class="flex flex-col gap-1">
            <input type="text" id="suffixInput" placeholder="Add Suffix..." class="bg-surface border border-border-default rounded px-3 py-1.5 text-sm text-text-primary focus-glow outline-none" />
          </div>
          <label class="flex items-center gap-2 cursor-pointer group mt-2">
            <input type="checkbox" id="cbNumber" class="w-4 h-4 rounded border-border-default bg-surface text-accent focus-glow" />
            <span class="text-sm text-text-primary group-hover:text-accent transition-colors">Add Line Numbers</span>
          </label>
        </div>

        <!-- Actions -->
        <div class="flex flex-col justify-end gap-3">
          <button id="processBtn" class="w-full py-3 bg-accent text-void font-bold rounded-lg hover:bg-accent-hover transition-colors focus-glow flex items-center justify-center gap-2 shadow-lg shadow-accent/20">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
            Clean List
          </button>
        </div>

      </div>
    </div>

    <!-- Stats Bar -->
    <div class="flex justify-between items-center px-2 text-sm">
      <div class="text-text-muted">
        Input Lines: <span id="statInput" class="font-mono text-text-primary font-bold">0</span>
      </div>
      <div class="text-info font-bold hidden" id="statBanner">
        Removed <span id="statDedup">0</span> duplicates!
      </div>
      <div class="text-text-muted">
        Output Lines: <span id="statOutput" class="font-mono text-accent font-bold">0</span>
      </div>
    </div>

    <!-- Panels -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      
      <!-- Input Panel -->
      <div class="flex flex-col h-[500px]">
        <div class="flex justify-between items-center mb-2 px-1">
          <label for="inputArea" class="text-sm font-semibold text-text-primary">Original List</label>
          <button id="clearBtn" class="text-xs text-text-muted hover:text-error transition-colors font-medium">Clear</button>
        </div>
        <textarea 
          id="inputArea" 
          class="flex-1 w-full bg-surface/50 border border-border-subtle rounded-xl p-4 font-mono text-sm text-text-primary resize-none focus-glow transition-colors whitespace-pre overflow-auto"
          placeholder="Paste your messy list here...&#10;apple&#10;banana&#10;apple  &#10;orange&#10;&#10;grape"
        ></textarea>
      </div>

      <!-- Output Panel -->
      <div class="flex flex-col h-[500px]">
        <div class="flex justify-between items-center mb-2 px-1">
          <label for="outputArea" class="text-sm font-semibold text-text-primary">Cleaned List</label>
          <div class="flex gap-3">
            <button id="copyBtn" class="text-xs text-accent hover:text-accent-hover transition-colors flex items-center gap-1 font-medium">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
              Copy
            </button>
            <button id="downloadBtn" class="text-xs text-accent hover:text-accent-hover transition-colors flex items-center gap-1 font-medium">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
              Download
            </button>
          </div>
        </div>
        <textarea 
          id="outputArea" 
          class="flex-1 w-full bg-void border border-border-subtle rounded-xl p-4 font-mono text-sm text-text-secondary resize-none focus-glow whitespace-pre overflow-auto"
          readonly
        ></textarea>
      </div>
      
    </div>
  </div>

  <Fragment slot="content">
    <HowToSection 
      title="How to Clean and Deduplicate Lists"
      steps={[
        {
          name: "Paste Your List",
          text: "Copy your messy data (like an email list, keyword list, or column from Excel) and paste it into the left text area.",
          description: "Copy your messy data (like an email list, keyword list, or column from Excel) and paste it into the left text area."
        },
        {
          name: "Select Cleaning Options",
          text: "By default, the tool will remove duplicate lines, trim invisible whitespace from the edges, and remove blank lines. You can customize this in the top panel.",
          description: "By default, the tool will remove duplicate lines, trim invisible whitespace from the edges, and remove blank lines. You can customize this in the top panel."
        },
        {
          name: "Choose a Sort Order",
          text: "Optionally, sort your list alphabetically, by string length, numerically, or even randomize it using the shuffle option.",
          description: "Optionally, sort your list alphabetically, by string length, numerically, or even randomize it using the shuffle option."
        },
        {
          name: "Process and Export",
          text: "Click 'Clean List'. The results will instantly appear on the right. You can then copy it back to your clipboard or download it as a text file.",
          description: "Click <strong>Clean List</strong>. The results will instantly appear on the right. You can then copy it back to your clipboard or download it as a text file."
        }
      ]}
    />
    <TechnicalExplainer 
      title="Common List Cleaning Tasks"
      sections={[
        {
          title: "Deduplication (Set Theory)",
          content: "Removing duplicates manually from a 10,000-line list is impossible. This tool uses a JavaScript <code>Set</code> data structure to guarantee O(n) linear time complexity when finding unique lines, making it instantaneous even for massive lists."
        },
        {
          title: "Whitespace Trimming",
          content: "A common issue when copying data from PDFs or websites is the inclusion of invisible trailing spaces or tabs. Because <code>'apple '</code> and <code>'apple'</code> are technically different strings, trimming whitespace before deduplicating is critical for accuracy."
        },
        {
          title: "Adding Prefixes / Suffixes",
          content: "The formatting tools allow you to quickly wrap your list items. For example, if you have a list of filenames, you can easily add <code>https://example.com/</code> as a prefix and <code>.jpg</code> as a suffix to convert them into full URLs."
        }
      ]}
    />
    <FaqSection 
      faqs={[
        {
          question: "Does 'Case Insensitive' deduplication alter the output?",
          text: "No. If 'Apple' and 'apple' are in your list, and you choose Case Insensitive, the tool will keep the first one it finds (e.g., 'Apple') and remove the subsequent duplicates, preserving your original capitalization.",
          answer: "No. If <code>Apple</code> and <code>apple</code> are in your list, and you choose Case Insensitive, the tool will keep the first one it finds (e.g., <code>Apple</code>) and remove the subsequent duplicates, preserving your original capitalization."
        },
        {
          question: "How does Numerical Sorting work?",
          text: "Numerical sorting attempts to extract the first number found in the line and sorts based on that mathematical value. For example, 'File 2' will be sorted before 'File 10' (whereas Alphabetical sorting would put 10 before 2).",
          answer: "Numerical sorting attempts to extract the first number found in the line and sorts based on that mathematical value. For example, 'File 2' will be sorted before 'File 10' (whereas Alphabetical sorting would put 10 before 2)."
        },
        {
          question: "Is there a limit to how many lines I can process?",
          text: "There is no hard limit. The tool runs entirely in your browser's memory. Most modern browsers can easily handle lists of 100,000+ lines in milliseconds. If you paste millions of lines, the browser tab might freeze temporarily.",
          answer: "There is no hard limit. The tool runs entirely in your browser's memory. Most modern browsers can easily handle lists of 100,000+ lines in milliseconds. If you paste millions of lines, the browser tab might freeze temporarily."
        }
      ]}
    />
  </Fragment>

  <script>
    import { copyToClipboard } from '../../lib/clipboard';
    import { downloadFile } from '../../lib/download';
    import { cleanList, type ListCleanerOptions } from '../../tools/list-cleaner';

    const inputArea = document.getElementById('inputArea') as HTMLTextAreaElement;
    const outputArea = document.getElementById('outputArea') as HTMLTextAreaElement;
    const clearBtn = document.getElementById('clearBtn')!;
    const copyBtn = document.getElementById('copyBtn')!;
    const downloadBtn = document.getElementById('downloadBtn')!;
    const processBtn = document.getElementById('processBtn')!;

    const cbDedup = document.getElementById('cbDedup') as HTMLInputElement;
    const cbCase = document.getElementById('cbCase') as HTMLInputElement;
    const cbTrim = document.getElementById('cbTrim') as HTMLInputElement;
    const cbEmpty = document.getElementById('cbEmpty') as HTMLInputElement;
    const sortMode = document.getElementById('sortMode') as HTMLSelectElement;
    const prefixInput = document.getElementById('prefixInput') as HTMLInputElement;
    const suffixInput = document.getElementById('suffixInput') as HTMLInputElement;
    const cbNumber = document.getElementById('cbNumber') as HTMLInputElement;

    const statInput = document.getElementById('statInput')!;
    const statOutput = document.getElementById('statOutput')!;
    const statDedup = document.getElementById('statDedup')!;
    const statBanner = document.getElementById('statBanner')!;

    // Toggle case sensitive checkbox state based on dedup
    cbDedup.addEventListener('change', () => {
      cbCase.disabled = !cbDedup.checked;
      if (!cbDedup.checked) {
        cbCase.parentElement?.classList.add('opacity-50');
      } else {
        cbCase.parentElement?.classList.remove('opacity-50');
      }
    });

    function runProcess() {
      const val = inputArea.value;
      if (!val) {
        outputArea.value = '';
        statInput.textContent = '0';
        statOutput.textContent = '0';
        statBanner.classList.add('hidden');
        return;
      }

      const options: ListCleanerOptions = {
        deduplicate: cbDedup.checked,
        caseInsensitiveDedup: cbCase.checked,
        trimWhitespace: cbTrim.checked,
        removeEmpty: cbEmpty.checked,
        sortMode: sortMode.value as any,
        prefix: prefixInput.value,
        suffix: suffixInput.value,
        addNumbers: cbNumber.checked
      };

      const res = cleanList(val, options);

      outputArea.value = res.output;
      statInput.textContent = res.stats.inputLines.toLocaleString();
      statOutput.textContent = res.stats.outputLines.toLocaleString();

      if (res.stats.duplicatesRemoved > 0) {
        statBanner.classList.remove('hidden');
        statDedup.textContent = res.stats.duplicatesRemoved.toLocaleString();
      } else {
        statBanner.classList.add('hidden');
      }
    }

    processBtn.addEventListener('click', runProcess);

    clearBtn.addEventListener('click', () => {
      inputArea.value = '';
      runProcess();
      inputArea.focus();
    });

    copyBtn.addEventListener('click', () => {
      if (outputArea.value) {
        copyToClipboard(outputArea.value, copyBtn, `
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          Copied!
        `);
      }
    });

    downloadBtn.addEventListener('click', () => {
      if (outputArea.value) {
        downloadFile(outputArea.value, 'cleaned_list.txt', 'text/plain;charset=utf-8;');
      }
    });

  </script>
</ToolLayout>
