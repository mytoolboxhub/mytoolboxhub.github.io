---
import ToolLayout from '../../layouts/ToolLayout.astro';
import HowToSection from '../../components/seo/HowToSection.astro';
import FaqSection from '../../components/seo/FaqSection.astro';
import TechnicalExplainer from '../../components/seo/TechnicalExplainer.astro';
import { tools } from '../../lib/tool-registry';

const tool = tools.find(t => t.id === 'mock-data-generator')!;
---

<ToolLayout tool={tool}>
  <div class="space-y-6">
    
    <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
      
      <!-- Left Panel: Schema Builder -->
      <div class="flex flex-col h-[600px]">
        <div class="flex justify-between items-center mb-2 px-1">
          <label class="text-sm font-semibold text-text-primary">Schema Definition</label>
          <div class="flex gap-2">
            <button id="clearSchemaBtn" class="text-xs text-text-muted hover:text-error transition-colors font-medium">Clear All</button>
            <button id="addFieldBtn" class="text-xs bg-surface border border-border-default px-2 py-1 rounded hover:border-accent hover:text-accent transition-colors font-medium flex items-center gap-1">
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
              Add Field
            </button>
          </div>
        </div>
        
        <div class="flex-1 bg-surface/30 border border-border-subtle rounded-xl flex flex-col overflow-hidden">
          
          <!-- Schema Headers -->
          <div class="flex items-center px-4 py-2 border-b border-border-subtle bg-surface/50 text-xs font-bold text-text-muted uppercase tracking-wider">
            <div class="w-1/3 pr-2">Field Name</div>
            <div class="w-1/3 px-2">Data Type</div>
            <div class="w-1/3 pl-2 text-right">Options</div>
          </div>
          
          <!-- Schema Rows Container -->
          <div id="schemaRows" class="flex-1 overflow-y-auto p-2 space-y-2">
            <!-- Rows injected by JS -->
          </div>
        </div>
      </div>

      <!-- Right Panel: Output -->
      <div class="flex flex-col h-[600px]">
        
        <!-- Controls Bar -->
        <div class="flex flex-wrap gap-3 items-end mb-2 px-1 bg-surface/30 p-3 rounded-xl border border-border-subtle">
          
          <div class="flex flex-col gap-1 w-20">
            <label for="rowCount" class="text-xs font-medium text-text-secondary">Rows</label>
            <input type="number" id="rowCount" min="1" max="1000" value="10" class="bg-void border border-border-default rounded px-2 py-1 text-sm text-text-primary focus-glow outline-none" />
          </div>

          <div class="flex flex-col gap-1 w-24">
            <label for="outFormat" class="text-xs font-medium text-text-secondary">Format</label>
            <select id="outFormat" class="bg-void border border-border-default rounded px-2 py-1 text-sm text-text-primary focus-glow outline-none">
              <option value="json">JSON</option>
              <option value="csv">CSV</option>
              <option value="sql">SQL</option>
            </select>
          </div>
          
          <div class="flex flex-col gap-1 flex-1 min-w-[120px] hidden" id="tableNameWrapper">
            <label for="tableName" class="text-xs font-medium text-text-secondary">Table Name</label>
            <input type="text" id="tableName" value="mock_data" class="bg-void border border-border-default rounded px-2 py-1 text-sm text-text-primary focus-glow outline-none" />
          </div>

          <button id="generateBtn" class="px-4 py-1.5 bg-accent text-void font-bold text-sm rounded hover:bg-accent-hover transition-colors focus-glow flex items-center gap-1 shadow-md shadow-accent/20 ml-auto h-[30px] self-end">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
            Generate
          </button>
        </div>

        <div class="flex justify-between items-center mb-1 mt-2 px-1">
          <label class="text-sm font-semibold text-text-primary">Preview</label>
          <div class="flex gap-3">
            <button id="copyBtn" class="text-xs text-accent hover:text-accent-hover transition-colors flex items-center gap-1 font-medium">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
              Copy
            </button>
            <button id="downloadBtn" class="text-xs text-accent hover:text-accent-hover transition-colors flex items-center gap-1 font-medium">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
              Download
            </button>
          </div>
        </div>
        
        <textarea 
          id="outputArea" 
          class="flex-1 w-full bg-void border border-border-subtle rounded-xl p-4 font-mono text-sm text-text-secondary resize-none focus-glow whitespace-pre overflow-auto"
          readonly
        ></textarea>
      </div>

    </div>
  </div>

  <Fragment slot="content">
    <HowToSection 
      title="How to Generate Mock Data"
      steps={[
        {
          name: "Define Your Schema",
          text: "In the left panel, add rows to define the structure of your data. Give each field a name (like 'id' or 'email') and select its data type from the dropdown.",
          description: "In the left panel, add rows to define the structure of your data. Give each field a name (like <code>id</code> or <code>email</code>) and select its data type from the dropdown."
        },
        {
          name: "Customize Options",
          text: "For specific types like Integers, Floats, or Custom Lists (oneOf), you can provide additional options like Min/Max ranges or comma-separated lists of values.",
          description: "For specific types like Integers, Floats, or Custom Lists (oneOf), you can provide additional options like Min/Max ranges or comma-separated lists of values."
        },
        {
          name: "Choose Output Format",
          text: "Select how many rows you need (up to 1,000) and choose your preferred output format: JSON array, CSV table, or SQL INSERT statements.",
          description: "Select how many rows you need (up to 1,000) and choose your preferred output format: JSON array, CSV table, or SQL INSERT statements."
        },
        {
          name: "Generate and Export",
          text: "Click the Generate button to instantly create the data. Use the Copy or Download buttons to export the results.",
          description: "Click the Generate button to instantly create the data. Use the Copy or Download buttons to export the results."
        }
      ]}
    />
    <TechnicalExplainer 
      title="Why Developers Need Mock Data"
      sections={[
        {
          title: "Prototyping UIs",
          content: "Before a backend API is finished, frontend developers need realistic data to build out UI components, test scrolling performance, and handle edge cases like very long names or missing fields."
        },
        {
          title: "Database Seeding",
          content: "When setting up a new development environment, an empty database is hard to work with. Generating thousands of rows of SQL INSERT statements allows developers to instantly populate a database to test queries and indexing performance."
        },
        {
          title: "Privacy and Security",
          content: "You should never use production customer data in a local development or staging environment. Generating fake, realistic data ensures you do not violate GDPR, HIPAA, or other data privacy regulations while testing."
        }
      ]}
    />
    <FaqSection 
      faqs={[
        {
          question: "Is this data truly random?",
          text: "The data is generated using your browser's pseudo-random number generator (Math.random()). While mathematically 'pseudo-random', it is perfectly sufficient for testing and prototyping purposes.",
          answer: "The data is generated using your browser's pseudo-random number generator (<code>Math.random()</code>). While mathematically 'pseudo-random', it is perfectly sufficient for testing and prototyping purposes."
        },
        {
          question: "Can I generate more than 1,000 rows?",
          text: "Currently, we cap generation at 1,000 rows to ensure your browser remains responsive and doesn't freeze. If you need 10,000 rows, you can run the generator 10 times and append the files.",
          answer: "Currently, we cap generation at 1,000 rows to ensure your browser remains responsive and doesn't freeze. If you need 10,000 rows, you can run the generator 10 times and append the files."
        },
        {
          question: "What is the 'oneOf' data type?",
          text: "The 'Custom List (oneOf)' type allows you to specify a comma-separated list of your own values. The generator will randomly pick one of those values for each row. For example, you could enter 'Pending, Active, Suspended' for an account status field.",
          answer: "The 'Custom List (oneOf)' type allows you to specify a comma-separated list of your own values. The generator will randomly pick one of those values for each row. For example, you could enter <code>Pending, Active, Suspended</code> for an account status field."
        }
      ]}
    />
  </Fragment>

  <script>
    import { copyToClipboard } from '../../lib/clipboard';
    import { downloadFile } from '../../lib/download';
    import { generateMockData, DATA_TYPES, type SchemaField, type ExportFormat } from '../../tools/mock-data';

    const schemaRowsContainer = document.getElementById('schemaRows')!;
    const addFieldBtn = document.getElementById('addFieldBtn')!;
    const clearSchemaBtn = document.getElementById('clearSchemaBtn')!;
    
    const rowCountInput = document.getElementById('rowCount') as HTMLInputElement;
    const outFormatSelect = document.getElementById('outFormat') as HTMLSelectElement;
    const tableNameWrapper = document.getElementById('tableNameWrapper')!;
    const tableNameInput = document.getElementById('tableName') as HTMLInputElement;
    const generateBtn = document.getElementById('generateBtn')!;
    const outputArea = document.getElementById('outputArea') as HTMLTextAreaElement;
    
    const copyBtn = document.getElementById('copyBtn')!;
    const downloadBtn = document.getElementById('downloadBtn')!;

    let rowIdCounter = 0;

    // Build the dropdown HTML once
    const typeOptionsHtml = DATA_TYPES.map(t => `<option value="${t.id}">${t.name}</option>`).join('');

    function addRow(defaultName: string = '', defaultType: string = 'uuid') {
      const id = `row_${rowIdCounter++}`;
      const row = document.createElement('div');
      row.className = 'flex items-center gap-2 bg-void border border-border-default rounded-lg p-2 group hover:border-accent/50 transition-colors';
      row.id = id;

      row.innerHTML = `
        <div class="w-1/3">
          <input type="text" class="schema-name w-full bg-transparent border-none p-1 text-sm text-text-primary focus:ring-0 outline-none font-mono" placeholder="field_name" value="${defaultName}">
        </div>
        <div class="w-1/3">
          <select class="schema-type w-full bg-surface border border-border-subtle rounded p-1 text-xs text-text-secondary focus-glow outline-none">
            ${typeOptionsHtml}
          </select>
        </div>
        <div class="w-1/3 flex items-center justify-between gap-2 pl-2">
          <div class="schema-options flex-1">
            <!-- Dynamic options injected here based on type -->
          </div>
          <button type="button" class="text-text-muted hover:text-error transition-colors px-1" onclick="document.getElementById('${id}').remove()">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
          </button>
        </div>
      `;

      schemaRowsContainer.appendChild(row);

      const typeSelect = row.querySelector('.schema-type') as HTMLSelectElement;
      const optionsContainer = row.querySelector('.schema-options') as HTMLElement;
      
      typeSelect.value = defaultType;

      const updateOptions = () => {
        const val = typeSelect.value;
        if (val === 'integer' || val === 'float') {
          optionsContainer.innerHTML = `
            <div class="flex gap-1">
              <input type="number" class="opt-min w-1/2 bg-surface border border-border-subtle rounded px-1 py-0.5 text-xs text-text-primary placeholder:text-text-muted outline-none" placeholder="Min" value="${val==='integer'?1:0}">
              <input type="number" class="opt-max w-1/2 bg-surface border border-border-subtle rounded px-1 py-0.5 text-xs text-text-primary placeholder:text-text-muted outline-none" placeholder="Max" value="100">
            </div>
          `;
        } else if (val === 'oneOf') {
          optionsContainer.innerHTML = `
            <input type="text" class="opt-list w-full bg-surface border border-border-subtle rounded px-1 py-0.5 text-xs text-text-primary placeholder:text-text-muted outline-none" placeholder="A, B, C">
          `;
        } else {
          optionsContainer.innerHTML = '';
        }
      };

      typeSelect.addEventListener('change', updateOptions);
      updateOptions();
    }

    // Initial default rows
    addRow('id', 'uuid');
    addRow('name', 'fullName');
    addRow('email', 'email');
    addRow('age', 'integer');
    addRow('isActive', 'boolean');

    addFieldBtn.addEventListener('click', () => addRow());
    clearSchemaBtn.addEventListener('click', () => {
      schemaRowsContainer.innerHTML = '';
      addRow('id', 'uuid');
    });

    outFormatSelect.addEventListener('change', () => {
      if (outFormatSelect.value === 'sql') {
        tableNameWrapper.classList.remove('hidden');
      } else {
        tableNameWrapper.classList.add('hidden');
      }
    });

    function getFullSchema(): SchemaField[] {
      const rows = Array.from(schemaRowsContainer.children);
      const schema: SchemaField[] = [];

      rows.forEach(row => {
        const nameInput = row.querySelector('.schema-name') as HTMLInputElement;
        const typeSelect = row.querySelector('.schema-type') as HTMLSelectElement;
        
        const name = nameInput.value.trim();
        if (!name) return; // Skip empty names

        const type = typeSelect.value;
        const field: SchemaField = { name, type };

        if (type === 'integer' || type === 'float') {
          const minI = row.querySelector('.opt-min') as HTMLInputElement;
          const maxI = row.querySelector('.opt-max') as HTMLInputElement;
          if (minI && minI.value) field.min = parseFloat(minI.value);
          if (maxI && maxI.value) field.max = parseFloat(maxI.value);
        } else if (type === 'oneOf') {
          const listI = row.querySelector('.opt-list') as HTMLInputElement;
          if (listI && listI.value) field.options = listI.value;
        }

        schema.push(field);
      });

      return schema;
    }

    function runGenerate() {
      const schema = getFullSchema();
      if (schema.length === 0) {
        outputArea.value = 'Please add at least one named field to your schema.';
        return;
      }

      let count = parseInt(rowCountInput.value, 10);
      if (isNaN(count) || count < 1) count = 1;
      if (count > 1000) count = 1000;
      rowCountInput.value = count.toString();

      const format = outFormatSelect.value as ExportFormat;
      const tableName = tableNameInput.value.trim() || 'mock_data';

      generateBtn.disabled = true;
      generateBtn.classList.add('opacity-50');

      // Small delay to allow UI refresh
      setTimeout(() => {
        const result = generateMockData(schema, count, format, tableName);
        outputArea.value = result;
        
        generateBtn.disabled = false;
        generateBtn.classList.remove('opacity-50');
      }, 10);
    }

    generateBtn.addEventListener('click', runGenerate);

    copyBtn.addEventListener('click', () => {
      if (outputArea.value) {
        copyToClipboard(outputArea.value, copyBtn, `
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          Copied!
        `);
      }
    });

    downloadBtn.addEventListener('click', () => {
      if (!outputArea.value) return;
      
      const format = outFormatSelect.value;
      let filename = 'mock_data';
      let mime = 'text/plain;charset=utf-8;';

      if (format === 'json') { filename += '.json'; mime = 'application/json;charset=utf-8;'; }
      if (format === 'csv') { filename += '.csv'; mime = 'text/csv;charset=utf-8;'; }
      if (format === 'sql') { filename += '.sql'; mime = 'application/sql;charset=utf-8;'; }

      downloadFile(outputArea.value, filename, mime);
    });

    // Generate once on load
    setTimeout(runGenerate, 100);

  </script>
</ToolLayout>
