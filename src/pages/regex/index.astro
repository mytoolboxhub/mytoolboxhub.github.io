---
import ToolLayout from '../../layouts/ToolLayout.astro';
import HowToSection from '../../components/seo/HowToSection.astro';
import FaqSection from '../../components/seo/FaqSection.astro';
import TechnicalExplainer from '../../components/seo/TechnicalExplainer.astro';
import { tools } from '../../lib/tool-registry';

const tool = tools.find(t => t.id === 'regex-tester')!;
---

<ToolLayout tool={tool}>
  <div class="space-y-6">
    
    <!-- Pattern Input -->
    <div class="glass p-6 rounded-2xl border-2 border-transparent focus-within:border-accent/50 transition-colors">
      <div class="flex items-center gap-2">
        <span class="text-2xl font-mono text-accent font-bold">/</span>
        <input 
          type="text" 
          id="patternInput" 
          class="flex-1 bg-transparent border-none text-xl md:text-2xl font-mono text-text-primary focus:ring-0 px-0 focus-glow-none"
          placeholder="^([a-z0-9_\.-]+)@([\da-z\.-]+)\.([a-z\.]{2,6})$"
          spellcheck="false"
        />
        <span class="text-2xl font-mono text-accent font-bold">/</span>
        <input 
          type="text" 
          id="flagsInput" 
          class="w-16 md:w-24 bg-transparent border-none text-xl md:text-2xl font-mono text-accent focus:ring-0 px-0 focus-glow-none"
          placeholder="gmi"
          value="gmi"
          spellcheck="false"
        />
      </div>
    </div>

    <!-- Error Banner -->
    <div id="errorBanner" class="hidden bg-error/10 border border-error/30 text-error px-4 py-3 rounded-lg text-sm flex items-start gap-3 animate-fade-in-down">
      <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      <div>
        <strong class="block font-semibold mb-1">Invalid Regular Expression</strong>
        <span id="errorMessage"></span>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      
      <!-- Test String Panel -->
      <div class="lg:col-span-2 flex flex-col h-[500px]">
        <div class="flex justify-between items-center mb-2">
          <label for="testStringInput" class="text-sm font-semibold text-text-primary">Test String</label>
        </div>
        
        <!-- We use a custom overlay technique for highlighting. The textarea handles input, the div handles background highlighting. -->
        <div class="relative flex-1 bg-surface/50 border border-border-subtle rounded-xl overflow-hidden font-mono text-sm leading-relaxed transition-colors focus-within:border-accent">
          <!-- Backdrop for highlighting -->
          <div id="highlights" class="absolute inset-0 p-4 whitespace-pre-wrap break-words text-transparent pointer-events-none overflow-auto"></div>
          <!-- Transparent Textarea -->
          <textarea 
            id="testStringInput" 
            class="absolute inset-0 w-full h-full bg-transparent border-none p-4 text-text-primary resize-none focus:ring-0 m-0 z-10"
            placeholder="Type your test string here..."
            spellcheck="false"
          >john.doe@example.com
invalid-email@
jane_smith123@company.co.uk</textarea>
        </div>
      </div>

      <!-- Results Panel -->
      <div class="flex flex-col h-[500px]">
        <div class="flex justify-between items-center mb-2">
          <label class="text-sm font-semibold text-text-primary">Match Results</label>
          <span id="matchStats" class="text-xs text-text-muted">0 matches</span>
        </div>
        
        <div id="resultsPanel" class="flex-1 bg-void border border-border-subtle rounded-xl p-4 overflow-y-auto space-y-4">
          <!-- Results populated by JS -->
          <div class="text-center text-text-muted text-sm mt-10">
            No matches found.
          </div>
        </div>
      </div>

    </div>
  </div>

  <Fragment slot="content">
    <HowToSection 
      title="How to Test Regular Expressions"
      steps={[
        {
          name: "Enter Your Pattern",
          text: "Type your regular expression into the large input bar at the top. Do not include the surrounding slashes (/).",
          description: "Type your regular expression into the large input bar at the top. Do not include the surrounding slashes (<code>/</code>)."
        },
        {
          name: "Adjust Flags",
          text: "Add or remove flags in the small input box on the right. 'g' (global) finds all matches, 'm' (multiline) makes ^ and $ match line breaks, and 'i' (ignore case) makes it case-insensitive.",
          description: "Add or remove flags in the small input box on the right. <code>g</code> (global) finds all matches, <code>m</code> (multiline) makes <code>^</code> and <code>$</code> match line breaks, and <code>i</code> (ignore case) makes it case-insensitive."
        },
        {
          name: "Type Test Data",
          text: "Paste your sample text into the main editor. The tool will instantly highlight matching text in blue.",
          description: "Paste your sample text into the main editor. The tool will instantly highlight matching text in blue."
        },
        {
          name: "Review Capture Groups",
          text: "Check the sidebar on the right to see a detailed breakdown of every match, including the exact extracted values for all your capture groups.",
          description: "Check the sidebar on the right to see a detailed breakdown of every match, including the exact extracted values for all your capture groups."
        }
      ]}
    />
    <TechnicalExplainer 
      title="Common Regex Patterns & Cheatsheet"
      sections={[
        {
          title: "Character Classes",
          content: "<ul class=\"list-disc pl-5 space-y-1 mt-2\"><li><code>.</code> : Any character except newline</li><li><code>\\w</code> : Word character (alphanumeric & underscore)</li><li><code>\\d</code> : Digit (0-9)</li><li><code>\\s</code> : Whitespace (space, tab, newline)</li><li><code>[A-Z]</code> : Character set (any uppercase letter)</li></ul>"
        },
        {
          title: "Quantifiers",
          content: "<ul class=\"list-disc pl-5 space-y-1 mt-2\"><li><code>*</code> : Zero or more times</li><li><code>+</code> : One or more times</li><li><code>?</code> : Zero or one time</li><li><code>{3}</code> : Exactly 3 times</li><li><code>{2,5}</code> : Between 2 and 5 times</li></ul>"
        },
        {
          title: "Anchors & Groups",
          content: "<ul class=\"list-disc pl-5 space-y-1 mt-2\"><li><code>^</code> : Start of string (or line with 'm' flag)</li><li><code>$</code> : End of string</li><li><code>(abc)</code> : Capture group (extracts 'abc')</li><li><code>(?:abc)</code> : Non-capturing group (groups without extracting)</li></ul>"
        }
      ]}
    />
    <FaqSection 
      faqs={[
        {
          question: "Which Regex flavor does this tool use?",
          text: "This tool uses the JavaScript (ECMAScript) Regular Expression engine, as it runs directly in your browser. While heavily compatible with PCRE, some advanced features like 'lookbehinds' may vary depending on your browser version.",
          answer: "This tool uses the <strong>JavaScript (ECMAScript)</strong> Regular Expression engine, as it runs directly in your browser. While heavily compatible with PCRE, some advanced features like 'lookbehinds' may vary depending on your browser version."
        },
        {
          question: "Why is it freezing my browser?",
          text: "You likely encountered 'Catastrophic Backtracking'. Certain complex regex patterns with nested quantifiers (like (a+)+$) can take exponentially long to fail on non-matching strings. We cap matches at 5,000 to prevent some crashes, but complex patterns can still lock up the JS thread.",
          answer: "You likely encountered 'Catastrophic Backtracking'. Certain complex regex patterns with nested quantifiers (like <code>(a+)+$</code>) can take exponentially long to fail on non-matching strings. We cap matches at 5,000 to prevent some crashes, but complex patterns can still lock up the JS thread."
        },
        {
          question: "What is the 'g' flag?",
          text: "The 'g' (global) flag tells the regex engine to find ALL matches in the string. Without it, the engine stops and returns only the very first match it finds.",
          answer: "The 'g' (global) flag tells the regex engine to find ALL matches in the string. Without it, the engine stops and returns only the very first match it finds."
        }
      ]}
    />
  </Fragment>

  <script>
    import { testRegex } from '../../tools/regex';

    const patternInput = document.getElementById('patternInput') as HTMLInputElement;
    const flagsInput = document.getElementById('flagsInput') as HTMLInputElement;
    const testStringInput = document.getElementById('testStringInput') as HTMLTextAreaElement;
    
    const highlights = document.getElementById('highlights')!;
    const errorBanner = document.getElementById('errorBanner')!;
    const errorMessage = document.getElementById('errorMessage')!;
    const resultsPanel = document.getElementById('resultsPanel')!;
    const matchStats = document.getElementById('matchStats')!;

    // Sync scroll
    testStringInput.addEventListener('scroll', () => {
      highlights.scrollTop = testStringInput.scrollTop;
      highlights.scrollLeft = testStringInput.scrollLeft;
    });

    function escapeHtml(str: string): string {
      return str
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }

    function processRegex() {
      const pattern = patternInput.value;
      const flags = flagsInput.value;
      const text = testStringInput.value;

      if (!pattern) {
        highlights.innerHTML = escapeHtml(text);
        resultsPanel.innerHTML = '<div class="text-center text-text-muted text-sm mt-10">Enter a pattern to see matches.</div>';
        matchStats.textContent = '0 matches';
        errorBanner.classList.add('hidden');
        return;
      }

      const res = testRegex(pattern, flags, text);

      if (!res.isValid) {
        errorBanner.classList.remove('hidden');
        errorMessage.textContent = res.error || 'Syntax Error';
        highlights.innerHTML = escapeHtml(text);
        resultsPanel.innerHTML = '<div class="text-center text-error text-sm mt-10">Invalid regular expression.</div>';
        matchStats.textContent = 'Error';
        return;
      }

      errorBanner.classList.add('hidden');
      matchStats.textContent = `${res.matches.length} match${res.matches.length !== 1 ? 'es' : ''} (${Math.round(res.executionTimeMs)}ms)`;

      // Render Sidebar Results
      if (res.matches.length === 0) {
        resultsPanel.innerHTML = '<div class="text-center text-text-muted text-sm mt-10">No matches found.</div>';
      } else {
        let html = '';
        res.matches.forEach((m, i) => {
          html += `<div class="bg-surface/50 border border-border-subtle rounded-lg p-3">
            <div class="flex justify-between items-center mb-2">
              <span class="text-xs font-bold text-accent">Match ${i + 1}</span>
              <span class="text-xs text-text-muted">Index: ${m.index}</span>
            </div>
            <div class="font-mono text-sm text-text-primary break-all bg-void px-2 py-1 rounded">${escapeHtml(m.text)}</div>
          `;
          
          if (m.groups && m.groups.length > 0) {
            html += `<div class="mt-2 space-y-1">`;
            m.groups.forEach((g, gi) => {
              if (g !== undefined) {
                html += `<div class="flex text-xs">
                  <span class="text-text-muted w-16 flex-shrink-0">Group ${gi + 1}:</span>
                  <span class="font-mono text-accent break-all">${escapeHtml(g)}</span>
                </div>`;
              }
            });
            html += `</div>`;
          }
          
          html += `</div>`;
        });
        resultsPanel.innerHTML = html;
      }

      // Render Highlights
      if (res.matches.length === 0) {
        highlights.innerHTML = escapeHtml(text);
      } else {
        let highlightedHtml = '';
        let lastIndex = 0;
        
        // We need to handle potential overlaps safely. Assuming non-overlapping matches from standard regex exec loop.
        for (const m of res.matches) {
          if (m.index >= lastIndex) {
            highlightedHtml += escapeHtml(text.substring(lastIndex, m.index));
            // Add highlighted match (using background color)
            highlightedHtml += `<mark class="bg-accent/30 text-transparent rounded-sm">${escapeHtml(m.text)}</mark>`;
            lastIndex = m.index + m.length;
          }
        }
        highlightedHtml += escapeHtml(text.substring(lastIndex));
        
        // Fix trailing newlines for perfect scroll alignment
        if (text.endsWith('\n')) {
          highlightedHtml += ' ';
        }
        
        highlights.innerHTML = highlightedHtml;
      }
    }

    patternInput.addEventListener('input', processRegex);
    flagsInput.addEventListener('input', processRegex);
    testStringInput.addEventListener('input', processRegex);

    // Initial run
    processRegex();
  </script>
</ToolLayout>
