---
import ToolLayout from '../../layouts/ToolLayout.astro';
import HowToSection from '../../components/seo/HowToSection.astro';
import FaqSection from '../../components/seo/FaqSection.astro';
import TechnicalExplainer from '../../components/seo/TechnicalExplainer.astro';
import { tools } from '../../lib/tool-registry';

const tool = tools.find(t => t.id === 'sql-formatter')!;
---

<ToolLayout tool={tool}>
  <div class="space-y-6">
    
    <!-- Controls Bar -->
    <div class="glass p-6 rounded-2xl flex flex-wrap gap-6 items-center justify-between">
      <div class="flex flex-wrap items-center gap-6">
        
        <div class="flex flex-col gap-2">
          <label for="indentSelect" class="text-sm font-medium text-text-secondary">Indentation</label>
          <select id="indentSelect" class="bg-surface border border-border-default rounded-md px-3 py-1.5 text-sm text-text-primary focus-glow outline-none">
            <option value="2">2 Spaces</option>
            <option value="4" selected>4 Spaces</option>
            <option value="tab">Tabs</option>
          </select>
        </div>

        <div class="flex flex-col gap-2">
          <span class="text-sm font-medium text-text-secondary">Formatting Options</span>
          <div class="flex gap-4">
            <label class="flex items-center gap-2 cursor-pointer group">
              <input type="checkbox" id="cbUpper" checked class="w-4 h-4 rounded border-border-default bg-surface text-accent focus-glow" />
              <span class="text-sm text-text-primary group-hover:text-accent transition-colors">Uppercase Keywords</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer group">
              <input type="checkbox" id="cbSemi" checked class="w-4 h-4 rounded border-border-default bg-surface text-accent focus-glow" />
              <span class="text-sm text-text-primary group-hover:text-accent transition-colors">Trailing Semicolon (;)</span>
            </label>
          </div>
        </div>

      </div>

      <button id="formatBtn" class="px-6 py-2.5 bg-accent text-void font-bold text-sm rounded-lg hover:bg-accent-hover transition-colors focus-glow flex items-center gap-2 shadow-lg shadow-accent/20">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>
        Format SQL
      </button>
    </div>

    <!-- Panels -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
      
      <!-- Input Panel -->
      <div class="flex flex-col h-[500px]">
        <div class="flex justify-between items-center mb-2 px-1">
          <label for="inputArea" class="text-sm font-semibold text-text-primary">Raw SQL Query</label>
          <button id="clearBtn" class="text-xs text-text-muted hover:text-error transition-colors font-medium">Clear</button>
        </div>
        <textarea 
          id="inputArea" 
          class="flex-1 w-full bg-surface/50 border border-border-subtle rounded-xl p-4 font-mono text-sm text-text-primary resize-none focus-glow transition-colors whitespace-pre overflow-auto"
          placeholder="select id, name, email from users inner join orders on users.id = orders.user_id where status = 'active' group by name order by created_at desc"
        ></textarea>
      </div>

      <!-- Output Panel -->
      <div class="flex flex-col h-[500px]">
        <div class="flex justify-between items-center mb-2 px-1">
          <label for="outputArea" class="text-sm font-semibold text-text-primary">Formatted SQL</label>
          <div class="flex gap-3">
            <button id="copyBtn" class="text-xs text-accent hover:text-accent-hover transition-colors flex items-center gap-1 font-medium">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
              Copy
            </button>
            <button id="downloadBtn" class="text-xs text-accent hover:text-accent-hover transition-colors flex items-center gap-1 font-medium">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
              Download
            </button>
          </div>
        </div>
        <textarea 
          id="outputArea" 
          class="flex-1 w-full bg-void border border-border-subtle rounded-xl p-4 font-mono text-sm text-accent resize-none focus-glow whitespace-pre overflow-auto"
          readonly
        ></textarea>
      </div>
      
    </div>
  </div>

  <Fragment slot="content">
    <HowToSection 
      title="How to Format SQL Queries"
      steps={[
        {
          name: "Paste Your Query",
          text: "Paste your raw, messy, or single-line SQL query into the left text area.",
          description: "Paste your raw, messy, or single-line SQL query into the left text area."
        },
        {
          name: "Configure Options",
          text: "Select your preferred indentation (Spaces vs Tabs). We highly recommend keeping 'Uppercase Keywords' enabled for standard SQL readability.",
          description: "Select your preferred indentation (Spaces vs Tabs). We highly recommend keeping 'Uppercase Keywords' enabled for standard SQL readability."
        },
        {
          name: "Format and Copy",
          text: "Click the 'Format SQL' button. The beautifully indented and colorized query will appear on the right, ready to be copied into your IDE or database client.",
          description: "Click the 'Format SQL' button. The beautifully indented and colorized query will appear on the right, ready to be copied into your IDE or database client."
        }
      ]}
    />
    <TechnicalExplainer 
      title="SQL Formatting Best Practices"
      sections={[
        {
          title: "Capitalization",
          content: "Standard SQL convention dictates that all reserved keywords (e.g., <code>SELECT</code>, <code>FROM</code>, <code>WHERE</code>, <code>INNER JOIN</code>) should be fully capitalized. Table names and column names should remain lowercase or snake_case. This creates visual separation."
        },
        {
          title: "Indentation Rules",
          content: "Major clause keywords should align to the left. Sub-clauses (like <code>AND</code> or <code>OR</code> inside a <code>WHERE</code> statement) should be indented one level deeper. Selected columns should be indented below the <code>SELECT</code> keyword."
        },
        {
          title: "Client-Side Processing",
          content: "Database queries often contain highly sensitive information (like column names, table structures, or inline data values). This formatter runs entirely in your browser using JavaScript, ensuring your schema is never transmitted over the internet."
        }
      ]}
    />
    <FaqSection 
      faqs={[
        {
          question: "Which SQL dialects are supported?",
          text: "This formatter uses generic SQL syntax rules, making it compatible with almost all major dialects including PostgreSQL, MySQL, SQL Server (T-SQL), SQLite, and Oracle.",
          answer: "This formatter uses generic SQL syntax rules, making it compatible with almost all major dialects including PostgreSQL, MySQL, SQL Server (T-SQL), SQLite, and Oracle."
        },
        {
          question: "Does it format nested subqueries?",
          text: "Yes. Parentheses () used for subqueries or function calls are automatically detected, and their contents are indented one level deeper than the surrounding query.",
          answer: "Yes. Parentheses <code>()</code> used for subqueries or function calls are automatically detected, and their contents are indented one level deeper than the surrounding query."
        },
        {
          question: "Why did it change my string capitalization?",
          text: "The 'Uppercase Keywords' option relies on a dictionary of SQL reserved words. If you have a column named 'select', it might be incorrectly capitalized. However, text inside single quotes (string literals) is completely preserved.",
          answer: "The 'Uppercase Keywords' option relies on a dictionary of SQL reserved words. If you have a column named 'select', it might be incorrectly capitalized. However, text inside single quotes (string literals) is completely preserved."
        }
      ]}
    />
  </Fragment>

  <script>
    import { copyToClipboard } from '../../lib/clipboard';
    import { downloadFile } from '../../lib/download';
    import { formatSql, type SqlFormatterOptions } from '../../tools/sql-formatter';

    const inputArea = document.getElementById('inputArea') as HTMLTextAreaElement;
    const outputArea = document.getElementById('outputArea') as HTMLTextAreaElement;
    const clearBtn = document.getElementById('clearBtn')!;
    const copyBtn = document.getElementById('copyBtn')!;
    const downloadBtn = document.getElementById('downloadBtn')!;
    const formatBtn = document.getElementById('formatBtn')!;

    const indentSelect = document.getElementById('indentSelect') as HTMLSelectElement;
    const cbUpper = document.getElementById('cbUpper') as HTMLInputElement;
    const cbSemi = document.getElementById('cbSemi') as HTMLInputElement;

    function runProcess() {
      const val = inputArea.value;
      if (!val) {
        outputArea.value = '';
        return;
      }

      let indentString = '    ';
      if (indentSelect.value === '2') indentString = '  ';
      if (indentSelect.value === 'tab') indentString = '\t';

      const options: SqlFormatterOptions = {
        indentString,
        uppercaseKeywords: cbUpper.checked,
        addTrailingSemicolon: cbSemi.checked
      };

      const res = formatSql(val, options);
      outputArea.value = res;
    }

    formatBtn.addEventListener('click', runProcess);

    clearBtn.addEventListener('click', () => {
      inputArea.value = '';
      runProcess();
      inputArea.focus();
    });

    copyBtn.addEventListener('click', () => {
      if (outputArea.value) {
        copyToClipboard(outputArea.value, copyBtn, `
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          Copied
        `);
      }
    });

    downloadBtn.addEventListener('click', () => {
      if (outputArea.value) {
        downloadFile(outputArea.value, 'query.sql', 'application/sql;charset=utf-8;');
      }
    });

  </script>
</ToolLayout>
