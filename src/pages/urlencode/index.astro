---
import ToolLayout from '../../layouts/ToolLayout.astro';
import HowToSection from '../../components/seo/HowToSection.astro';
import FaqSection from '../../components/seo/FaqSection.astro';
import TechnicalExplainer from '../../components/seo/TechnicalExplainer.astro';
import { tools } from '../../lib/tool-registry';

const tool = tools.find(t => t.id === 'url-encoder')!;
---

<ToolLayout tool={tool}>
  <div class="space-y-6">
    <!-- Controls -->
    <div class="glass p-4 flex flex-wrap gap-6 items-center justify-between">
      <div class="flex items-center gap-6">
        <div class="flex bg-surface border border-border-default rounded-lg p-1">
          <button id="modeEncode" class="px-4 py-1.5 text-sm font-medium rounded-md bg-accent text-void transition-all focus-glow">Encode</button>
          <button id="modeDecode" class="px-4 py-1.5 text-sm font-medium rounded-md text-text-secondary hover:text-text-primary transition-all focus-glow">Decode</button>
        </div>
        
        <div class="flex items-center gap-2">
          <label for="encodeMode" class="text-sm font-medium text-text-secondary">Encoding Type</label>
          <select id="encodeMode" class="bg-surface border border-border-default rounded-md px-2 py-1 text-sm text-text-primary focus-glow">
            <option value="component">Query Parameter (encodeURIComponent)</option>
            <option value="full">Full URL (encodeURI)</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Error Banner -->
    <div id="errorBanner" class="hidden bg-error/10 border border-error/30 text-error px-4 py-3 rounded-lg text-sm flex items-start gap-3 animate-fade-in-down">
      <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <div>
        <strong class="block font-semibold mb-1">Error</strong>
        <span id="errorMessage"></span>
      </div>
    </div>

    <!-- Layout Grid -->
    <div class="grid grid-cols-1 gap-6">
      
      <!-- Input Panel -->
      <div class="flex flex-col">
        <div class="flex justify-between items-center mb-2">
          <label id="inputLabel" for="input" class="text-sm font-semibold text-text-primary">String to Encode</label>
          <button id="clearBtn" class="text-xs text-text-muted hover:text-error transition-colors font-medium">Clear</button>
        </div>
        <textarea 
          id="input" 
          class="min-h-[150px] w-full bg-surface/50 border border-border-subtle rounded-xl p-4 font-mono text-sm text-text-primary resize-y focus-glow transition-colors"
          placeholder="Paste URL or parameter here..."
          spellcheck="false"
        ></textarea>
      </div>

      <!-- Arrow Divider -->
      <div class="flex justify-center -my-3 relative z-10 hidden sm:flex">
        <div class="bg-surface border border-border-subtle p-2 rounded-full text-accent shadow-lg">
          <svg class="w-5 h-5 transform rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>
        </div>
      </div>

      <!-- Output Panel -->
      <div class="flex flex-col">
        <div class="flex justify-between items-center mb-2">
          <label id="outputLabel" for="output" class="text-sm font-semibold text-text-primary">Encoded Result</label>
          <button id="copyBtn" class="text-xs text-accent hover:text-accent-hover transition-colors flex items-center gap-1 font-medium">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
            Copy
          </button>
        </div>
        <textarea 
          id="output" 
          class="min-h-[150px] w-full bg-void border border-border-subtle rounded-xl p-4 font-mono text-sm text-text-secondary resize-y focus-glow"
          placeholder="Result will appear here..."
          readonly
        ></textarea>
      </div>

      <!-- URL Breakdown Table (Shown only when a full URL is parsed) -->
      <div id="urlBreakdown" class="hidden glass p-6 rounded-xl mt-4">
        <h3 class="text-sm font-semibold text-text-primary mb-4">URL Breakdown</h3>
        <div class="overflow-x-auto">
          <table class="w-full text-sm text-left">
            <tbody id="urlTableBody" class="divide-y divide-border-subtle text-text-secondary">
              <!-- Populated by JS -->
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </div>

  <Fragment slot="content">
    <HowToSection 
      title="How to Encode and Decode URLs Online"
      steps={[
        {
          name: "Choose Your Mode",
          text: "Select whether you want to encode a standard string into a URL-safe format, or decode an already-encoded URL back into readable text.",
          description: "Select whether you want to <strong>Encode</strong> a standard string into a URL-safe format, or <strong>Decode</strong> an already-encoded URL back into readable text using the toggle at the top."
        },
        {
          name: "Select the Encoding Type",
          text: "Choose 'Query Parameter' if you are encoding a single value (like a search query). Choose 'Full URL' if you are encoding a complete web address including http://.",
          description: "Choose <strong>Query Parameter</strong> (<code>encodeURIComponent</code>) if you are encoding a single value (like a search query). Choose <strong>Full URL</strong> (<code>encodeURI</code>) if you are encoding a complete web address including <code>http://</code>."
        },
        {
          name: "Paste Your Text",
          text: "Type or paste your text into the top box. The tool will instantly process your input.",
          description: "Type or paste your text into the top box. The tool will instantly process your input."
        },
        {
          name: "Copy the Result",
          text: "Click the Copy button to copy your converted URL or parameter directly to your clipboard.",
          description: "Click the <strong>Copy</strong> button to copy your converted URL or parameter directly to your clipboard."
        }
      ]}
    />
    <TechnicalExplainer 
      title="URL Encoding (Percent-Encoding) Explained"
      sections={[
        {
          title: "Why Do We Need URL Encoding?",
          content: "URLs can only be sent over the Internet using the ASCII character-set. Furthermore, certain characters like <code>?</code>, <code>&</code>, <code>=</code>, and <code>#</code> have special reserved meanings within a URL (they dictate structure). If your data contains spaces, special characters, or reserved characters (like an <code>&</code> inside a search query), it must be translated into a valid ASCII format so the browser doesn't misinterpret the URL's structure."
        },
        {
          title: "How Percent-Encoding Works",
          content: "URL encoding replaces unsafe ASCII characters with a <code>%</code> followed by two hexadecimal digits representing the character's ASCII/UTF-8 value. For example, a space becomes <code>%20</code>, and the <code>&</code> character becomes <code>%26</code>."
        },
        {
          title: "encodeURI vs. encodeURIComponent",
          content: "<ul class=\"space-y-2 list-disc pl-5 mt-2\"><li><strong>encodeURI (Full URL):</strong> Used to encode an entire working URL. It ignores protocol and domain structural characters like <code>:</code>, <code>/</code>, <code>?</code>, and <code>&</code>.</li><li><strong>encodeURIComponent (Query Parameter):</strong> Used to encode an individual value that you are inserting <em>into</em> a URL. It encodes almost everything, including <code>/</code> and <code>?</code>, ensuring the value doesn't break the URL structure.</li></ul>"
        }
      ]}
    />
    <FaqSection 
      faqs={[
        {
          question: "Is this tool completely secure?",
          text: "Yes. All encoding and decoding happens entirely in your browser using JavaScript. No data is ever sent to our servers.",
          answer: "Yes. All encoding and decoding happens entirely in your browser using JavaScript. No data is ever sent to our servers."
        },
        {
          question: "Why did my spaces turn into %20?",
          text: "Spaces are not allowed in URLs. The official percent-encoded value for a space character in UTF-8 is %20. (In some specific form-submission contexts, spaces are represented as +, but %20 is universally recognized in URLs).",
          answer: "Spaces are not allowed in URLs. The official percent-encoded value for a space character in UTF-8 is <code>%20</code>. (In some specific form-submission contexts, spaces are represented as <code>+</code>, but <code>%20</code> is universally recognized in URLs)."
        },
        {
          question: "What is a 'Malformed URI sequence' error?",
          text: "This occurs during decoding when the tool encounters a percent-sign (%) that isn't followed by two valid hexadecimal digits, or encounters an invalid UTF-8 byte sequence. It means the string you are trying to decode is corrupted or wasn't properly encoded in the first place.",
          answer: "This occurs during decoding when the tool encounters a percent-sign (<code>%</code>) that isn't followed by two valid hexadecimal digits, or encounters an invalid UTF-8 byte sequence. It means the string you are trying to decode is corrupted or wasn't properly encoded in the first place."
        }
      ]}
    />
  </Fragment>

  <script>
    import { copyToClipboard } from '../../lib/clipboard';
    import { encodeUrl, decodeUrl, parseUrlParts } from '../../tools/url-encoder';

    let mode: 'encode' | 'decode' = 'encode';

    const input = document.getElementById('input') as HTMLTextAreaElement;
    const output = document.getElementById('output') as HTMLTextAreaElement;
    const errorBanner = document.getElementById('errorBanner')!;
    const errorMessage = document.getElementById('errorMessage')!;
    
    const modeEncodeBtn = document.getElementById('modeEncode')!;
    const modeDecodeBtn = document.getElementById('modeDecode')!;
    const encodeModeSelect = document.getElementById('encodeMode') as HTMLSelectElement;

    const inputLabel = document.getElementById('inputLabel')!;
    const outputLabel = document.getElementById('outputLabel')!;
    const clearBtn = document.getElementById('clearBtn')!;
    const copyBtn = document.getElementById('copyBtn')!;

    const urlBreakdown = document.getElementById('urlBreakdown')!;
    const urlTableBody = document.getElementById('urlTableBody')!;

    function setMode(newMode: 'encode' | 'decode') {
      mode = newMode;
      const activeClass = ['bg-accent', 'text-void'];
      const inactiveClass = ['bg-transparent', 'text-text-secondary'];

      if (mode === 'encode') {
        modeEncodeBtn.classList.add(...activeClass);
        modeEncodeBtn.classList.remove(...inactiveClass);
        modeDecodeBtn.classList.add(...inactiveClass);
        modeDecodeBtn.classList.remove(...activeClass);
        
        inputLabel.textContent = 'String to Encode';
        outputLabel.textContent = 'Encoded Result';
      } else {
        modeDecodeBtn.classList.add(...activeClass);
        modeDecodeBtn.classList.remove(...inactiveClass);
        modeEncodeBtn.classList.add(...inactiveClass);
        modeEncodeBtn.classList.remove(...activeClass);
        
        inputLabel.textContent = 'String to Decode';
        outputLabel.textContent = 'Decoded Result';
      }
      
      processConversion();
    }

    function renderUrlBreakdown(val: string) {
      // Only attempt breakdown if mode is full URL, or if we can successfully parse it
      const parts = parseUrlParts(val);
      
      if (!parts) {
        urlBreakdown.classList.add('hidden');
        return;
      }

      urlBreakdown.classList.remove('hidden');
      
      let rows = `
        <tr><td class="py-2 pr-4 font-medium text-text-primary w-1/4">Protocol</td><td class="py-2 break-all">${parts.protocol}</td></tr>
        <tr><td class="py-2 pr-4 font-medium text-text-primary">Host</td><td class="py-2 break-all">${parts.host}</td></tr>
        <tr><td class="py-2 pr-4 font-medium text-text-primary">Path</td><td class="py-2 break-all">${parts.path}</td></tr>
      `;

      if (parts.query) {
        rows += `<tr><td class="py-2 pr-4 font-medium text-text-primary align-top">Query Params</td><td class="py-2">
          <div class="space-y-1">`;
        
        for (const [key, value] of Object.entries(parts.queryParams)) {
          rows += `<div class="flex gap-2 text-xs"><span class="text-accent font-mono">${key}:</span> <span class="break-all font-mono">${value}</span></div>`;
        }
        
        rows += `</div></td></tr>`;
      }

      if (parts.fragment) {
        rows += `<tr><td class="py-2 pr-4 font-medium text-text-primary">Fragment</td><td class="py-2 break-all">${parts.fragment}</td></tr>`;
      }

      urlTableBody.innerHTML = rows;
    }

    function processConversion() {
      errorBanner.classList.add('hidden');
      const val = input.value;
      const type = encodeModeSelect.value as 'component' | 'full';
      
      if (!val) {
        output.value = '';
        urlBreakdown.classList.add('hidden');
        return;
      }

      try {
        if (mode === 'encode') {
          output.value = encodeUrl(val, type);
          urlBreakdown.classList.add('hidden'); // Show breakdown on decode usually
        } else {
          const res = decodeUrl(val, type);
          if (res.isValid) {
            output.value = res.result;
            // Only try to parse full URLs
            if (res.result.startsWith('http://') || res.result.startsWith('https://')) {
              renderUrlBreakdown(res.result);
            } else {
              urlBreakdown.classList.add('hidden');
            }
          } else {
            output.value = '';
            urlBreakdown.classList.add('hidden');
            errorBanner.classList.remove('hidden');
            errorMessage.textContent = res.error || 'Invalid format';
          }
        }
      } catch (e: any) {
        output.value = '';
        urlBreakdown.classList.add('hidden');
        errorBanner.classList.remove('hidden');
        errorMessage.textContent = e.message;
      }
    }

    modeEncodeBtn.addEventListener('click', () => setMode('encode'));
    modeDecodeBtn.addEventListener('click', () => setMode('decode'));
    encodeModeSelect.addEventListener('change', processConversion);
    input.addEventListener('input', processConversion);

    clearBtn.addEventListener('click', () => {
      input.value = '';
      processConversion();
    });

    copyBtn.addEventListener('click', () => {
      if (output.value) {
        copyToClipboard(output.value, copyBtn, `
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          Copied!
        `);
      }
    });

  </script>
</ToolLayout>
