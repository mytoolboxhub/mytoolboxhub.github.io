---
import ToolLayout from '../../layouts/ToolLayout.astro';
import HowToSection from '../../components/seo/HowToSection.astro';
import FaqSection from '../../components/seo/FaqSection.astro';
import TechnicalExplainer from '../../components/seo/TechnicalExplainer.astro';
import { tools } from '../../lib/tool-registry';

const tool = tools.find(t => t.id === 'word-counter')!;
---

<ToolLayout tool={tool}>
  <div class="space-y-6">
    
    <!-- Top Stats Bar -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="glass p-4 rounded-xl flex flex-col items-center justify-center text-center">
        <span class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-1">Words</span>
        <span id="statWords" class="text-3xl font-bold text-accent font-mono">0</span>
      </div>
      <div class="glass p-4 rounded-xl flex flex-col items-center justify-center text-center">
        <span class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-1">Characters</span>
        <span id="statChars" class="text-3xl font-bold text-text-primary font-mono">0</span>
      </div>
      <div class="glass p-4 rounded-xl flex flex-col items-center justify-center text-center">
        <span class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-1">Sentences</span>
        <span id="statSentences" class="text-3xl font-bold text-text-primary font-mono">0</span>
      </div>
      <div class="glass p-4 rounded-xl flex flex-col items-center justify-center text-center">
        <span class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-1">Paragraphs</span>
        <span id="statParagraphs" class="text-3xl font-bold text-text-primary font-mono">0</span>
      </div>
    </div>

    <!-- Main Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      
      <!-- Input Area (Takes up 2/3 on large screens) -->
      <div class="lg:col-span-2 flex flex-col h-[500px]">
        <div class="flex justify-between items-center mb-2">
          <label for="input" class="text-sm font-semibold text-text-primary">Your Text</label>
          <div class="flex gap-3">
            <button id="clearBtn" class="text-xs text-text-muted hover:text-error transition-colors font-medium">Clear</button>
            <button id="copyBtn" class="text-xs text-accent hover:text-accent-hover transition-colors flex items-center gap-1 font-medium">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
              Copy
            </button>
          </div>
        </div>
        <textarea 
          id="input" 
          class="flex-1 w-full bg-surface/50 border border-border-subtle rounded-xl p-4 text-base text-text-primary resize-none focus-glow transition-colors leading-relaxed"
          placeholder="Start typing or paste your text here..."
        ></textarea>
      </div>

      <!-- Advanced Stats Panel (Takes up 1/3 on large screens) -->
      <div class="flex flex-col gap-6">
        
        <!-- Reading Time -->
        <div class="glass p-6 rounded-xl">
          <h3 class="text-sm font-semibold text-text-primary mb-4 flex items-center gap-2">
            <svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            Reading Time
          </h3>
          <div class="flex items-end gap-2">
            <span id="statReadMins" class="text-2xl font-bold text-text-primary font-mono">0</span>
            <span class="text-sm text-text-secondary mb-1">min</span>
            <span id="statReadSecs" class="text-2xl font-bold text-text-primary font-mono ml-2">0</span>
            <span class="text-sm text-text-secondary mb-1">sec</span>
          </div>
          <p class="text-xs text-text-muted mt-2">Based on ~200 words per minute.</p>
        </div>

        <!-- Keyword Density -->
        <div class="glass p-6 rounded-xl flex-1 overflow-hidden flex flex-col">
          <h3 class="text-sm font-semibold text-text-primary mb-4 flex items-center gap-2">
            <svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
            Top Keywords
          </h3>
          <div class="overflow-y-auto pr-2">
            <ul id="keywordList" class="space-y-3">
              <li class="text-sm text-text-muted italic">Type some text to see keywords...</li>
            </ul>
          </div>
        </div>

      </div>

    </div>
  </div>

  <Fragment slot="content">
    <HowToSection 
      title="How to Use the Word Counter"
      steps={[
        {
          name: "Type or Paste Text",
          text: "Simply type or paste your text into the large text area. The tool will automatically calculate metrics as you type.",
          description: "Simply type or paste your text into the large text area. The tool will automatically calculate metrics as you type."
        },
        {
          name: "View Basic Metrics",
          text: "Look at the top row to instantly see the total word count, character count, sentences, and paragraphs.",
          description: "Look at the top row to instantly see the total <strong>word count</strong>, <strong>character count</strong>, sentences, and paragraphs."
        },
        {
          name: "Analyze Reading Time",
          text: "Check the right sidebar to see the estimated reading time, calculated based on an average reading speed of 200 words per minute.",
          description: "Check the right sidebar to see the estimated reading time, calculated based on an average reading speed of 200 words per minute."
        },
        {
          name: "Review Keyword Density",
          text: "The bottom right panel shows your top 10 most used keywords (excluding common stop words like 'the' or 'and'). This is highly useful for SEO optimization.",
          description: "The bottom right panel shows your top 10 most used keywords (excluding common stop words like 'the' or 'and'). This is highly useful for SEO optimization."
        }
      ]}
    />
    <TechnicalExplainer 
      title="How Text Metrics Are Calculated"
      sections={[
        {
          title: "Word Counting Logic",
          content: "Words are calculated by splitting the text by any whitespace character (spaces, tabs, newlines). This means hyphenated words (e.g., 'state-of-the-art') are counted as a single word, which aligns with standard typographical rules."
        },
        {
          title: "Sentences and Paragraphs",
          content: "Sentences are identified by looking for terminal punctuation marks: periods, exclamation points, and question marks (<code>.!?</code>). Paragraphs are simply counted by looking for line breaks (<code>\\n</code>) in the text."
        },
        {
          title: "Keyword Density and Stop Words",
          content: "To provide meaningful keyword density analysis, this tool automatically filters out common English 'stop words' (e.g., <em>the, is, at, which, on</em>). The remaining words are converted to lowercase and stripped of punctuation before being tallied, ensuring 'Apple' and 'apple,' count as the same word."
        }
      ]}
    />
    <FaqSection 
      faqs={[
        {
          question: "Is my text saved or sent to a server?",
          text: "No. The word counter is completely strictly client-side. Your text is never sent over the internet or saved anywhere.",
          answer: "No. The word counter is completely strictly client-side. Your text is never sent over the internet or saved anywhere."
        },
        {
          question: "What is the difference between characters with and without spaces?",
          text: "The standard 'Characters' count includes every space, tab, and line break. If you need a count strictly of letters, numbers, and symbols, this is often required for specific ad platforms or strict social media limits.",
          answer: "The standard 'Characters' count includes every space, tab, and line break. If you need a count strictly of letters, numbers, and symbols, this is often required for specific ad platforms or strict social media limits."
        },
        {
          question: "How accurate is the reading time estimation?",
          text: "The reading time is an estimate based on the widely accepted average adult reading speed of 200 to 250 words per minute. Technical or complex texts may take longer to read.",
          answer: "The reading time is an estimate based on the widely accepted average adult reading speed of 200 to 250 words per minute. Technical or complex texts may take longer to read."
        }
      ]}
    />
  </Fragment>

  <script>
    import { copyToClipboard } from '../../lib/clipboard';
    import { analyzeText } from '../../tools/word-counter';

    const input = document.getElementById('input') as HTMLTextAreaElement;
    const clearBtn = document.getElementById('clearBtn')!;
    const copyBtn = document.getElementById('copyBtn')!;

    const statWords = document.getElementById('statWords')!;
    const statChars = document.getElementById('statChars')!;
    const statSentences = document.getElementById('statSentences')!;
    const statParagraphs = document.getElementById('statParagraphs')!;
    
    const statReadMins = document.getElementById('statReadMins')!;
    const statReadSecs = document.getElementById('statReadSecs')!;
    const keywordList = document.getElementById('keywordList')!;

    function processText() {
      const stats = analyzeText(input.value);
      
      statWords.textContent = stats.words.toString();
      statChars.textContent = stats.characters.toString();
      statSentences.textContent = stats.sentences.toString();
      statParagraphs.textContent = stats.paragraphs.toString();
      
      statReadMins.textContent = stats.readingTimeMinutes.toString();
      statReadSecs.textContent = stats.readingTimeSeconds.toString();

      if (stats.topKeywords.length === 0) {
        keywordList.innerHTML = '<li class="text-sm text-text-muted italic">Type some text to see keywords...</li>';
      } else {
        keywordList.innerHTML = stats.topKeywords.map(k => `
          <li class="flex justify-between items-center bg-surface/50 px-3 py-2 rounded-lg border border-border-subtle">
            <span class="text-sm font-medium text-text-primary capitalize truncate mr-2" title="${k.word}">${k.word}</span>
            <span class="text-xs font-bold text-accent bg-accent/10 px-2 py-0.5 rounded-full">${k.count}</span>
          </li>
        `).join('');
      }
    }

    input.addEventListener('input', processText);

    clearBtn.addEventListener('click', () => {
      input.value = '';
      processText();
      input.focus();
    });

    copyBtn.addEventListener('click', () => {
      if (input.value) {
        copyToClipboard(input.value, copyBtn, `
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          Copied!
        `);
      }
    });

  </script>
</ToolLayout>
